1e:T6fa,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Why exactly 62%? Where does that number come from?","acceptedAnswer":{"@type":"Answer","text":"The 62% figure comes from a 2025 UK micro-business communications survey that analysed 500,000+ call attempts across 2,000 small businesses. Trade businesses specifically had the lowest answer rate of any sector surveyed."}},{"@type":"Question","name":"Does the 62% include spam and wrong numbers?","acceptedAnswer":{"@type":"Answer","text":"No — the 62% refers to all incoming calls, but even when filtering out obvious spam, the genuine enquiry miss rate remains above 50%. Tradespeople simply cannot answer while working."}},{"@type":"Question","name":"Will customers think I'm unprofessional if AI answers?","acceptedAnswer":{"@type":"Answer","text":"The alternative is voicemail or no answer at all — both of which customers find far more frustrating. In surveys, 85% of callers prefer speaking to a helpful AI over leaving a voicemail. And 78% hire the first responder regardless of whether it's human or AI."}},{"@type":"Question","name":"Can I still answer calls myself when I'm able?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. AI only answers calls you miss. If you pick up, the call connects to you normally. AI is the safety net, not the primary receiver. Most users find they personally answer 30-40% of calls and AI handles the rest."}},{"@type":"Question","name":"What if I only get 1-2 calls per day?","acceptedAnswer":{"@type":"Answer","text":"Even 1-2 missed calls per day equals 250-500 missed enquiries per year. At 35% conversion and £280 average job value, that's £24,500-£49,000 in lost annual revenue. The ROI is compelling regardless of call volume."}}]}13:["$","div",null,{"className":"min-h-screen bg-[var(--navy-900)] text-white","children":[["$","$L1d",null,{}],["$","script",null,{"id":"blog-post-article-schema","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Why 62% of Trade Business Calls Go Unanswered (and How to Fix It)\",\"description\":\"62% of trade business calls go unanswered because tradespeople are working when customers call. See why and how AI fixes it permanently. 2026 data.\",\"image\":\"https://whoza.ai/og-image.webp\",\"datePublished\":\"2026-05-08\",\"dateModified\":\"2026-05-08\",\"author\":{\"@type\":\"Person\",\"name\":\"Dru McPherson\",\"jobTitle\":\"Founder, whoza.ai\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Whoza.ai\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://whoza.ai/og-image.webp\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://whoza.ai/blog/why-62-percent-of-trade-business-calls-go-unanswered\"},\"articleSection\":\"Industry Insights\",\"wordCount\":1915,\"inLanguage\":\"en-GB\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\"article h1\",\"article h2\",\"article p\"]}}"}}],null,["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1e"}}],["$","$L1f",null,{"items":[{"name":"Home","item":"https://whoza.ai"},{"name":"Blog","item":"https://whoza.ai/blog"},{"name":"Why 62% of Trade Business Calls Go Unanswered (and How to Fix It)","item":"https://whoza.ai/blog/why-62-percent-of-trade-business-calls-go-unanswered"}]}],["$","main",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20","children":[["$","$L20",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-white/50 hover:text-emerald-400 transition-colors mb-8","children":["$L21","Back to Blog"]}],"$L22","$L23","$L24"]}],"$L25"]}]
