1e:T97c,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How many Google reviews should a tradesperson have?","acceptedAnswer":{"@type":"Answer","text":"Aim for 50+ reviews to be competitive in most local markets. The top 5% of trade businesses in any area typically have 50-100+ reviews. If you have fewer than 10, you're at a significant disadvantage. If you have 100+, you're the dominant player. Focus on consistent collection — 5-10 new reviews per month is better than 50 reviews all at once."}},{"@type":"Question","name":"Can I ask customers for Google reviews?","acceptedAnswer":{"@type":"Answer","text":"Yes, absolutely. Google explicitly encourages businesses to ask for reviews. What you can't do is offer incentives in exchange for reviews (e.g., 'Leave a review and get £10 off'). That violates Google's policies and can result in review removal or account suspension. Asking is fine. Incentivising is not."}},{"@type":"Question","name":"What if a customer leaves a negative review?","acceptedAnswer":{"@type":"Answer","text":"Respond professionally within 24 hours. Apologise for their experience, acknowledge the issue, and offer to make it right. Take the conversation offline: 'Please call us on [number] so we can sort this out.' A professional response to a negative review often impresses potential customers more than having no negative reviews at all. It shows you care about service quality."}},{"@type":"Question","name":"How do I get my Google review link?","acceptedAnswer":{"@type":"Answer","text":"In your Google Business Profile dashboard, go to 'Ask for reviews' or 'Get more reviews' in the left menu. Google will generate a short link that goes directly to your review form. You can also find it by searching your business on Google Maps, clicking 'Write a review,' and copying the URL. Test the link on your own phone before sending it to customers."}},{"@type":"Question","name":"Do reviews on other platforms matter?","acceptedAnswer":{"@type":"Answer","text":"Yes, but Google reviews matter most for Google search rankings. Reviews on Checkatrade, Rated People, TrustATrader, and Yelp are valuable for credibility on those platforms and can influence customer decisions. However, for local SEO and Google Maps ranking, Google reviews carry the most weight. Prioritise Google reviews, but collect reviews on other platforms where you're active too."}}]}13:["$","div",null,{"className":"min-h-screen bg-[var(--navy-900)] text-white","children":[["$","$L1d",null,{}],["$","script",null,{"id":"blog-post-article-schema","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"How to Get More Google Reviews: A Complete Guide for UK Trades\",\"description\":\"Google reviews are the #1 trust signal for customers. Learn how to collect them consistently, handle negative feedback, and turn reviews into revenue. 2026.\",\"image\":\"https://whoza.ai/og-image.webp\",\"datePublished\":\"2026-06-05\",\"dateModified\":\"2026-06-05\",\"author\":{\"@type\":\"Person\",\"name\":\"Dru McPherson\",\"jobTitle\":\"Founder, whoza.ai\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Whoza.ai\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://whoza.ai/og-image.webp\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://whoza.ai/blog/how-to-get-more-google-reviews-trades\"},\"articleSection\":\"Trade Business Tips\",\"wordCount\":2464,\"inLanguage\":\"en-GB\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\"article h1\",\"article h2\",\"article p\"]}}"}}],null,["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1e"}}],"$L1f","$L20","$L21"]}]
