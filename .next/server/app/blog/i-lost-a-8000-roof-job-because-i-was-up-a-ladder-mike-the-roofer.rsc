1e:T7b0,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much does AI call answering cost for roofers?","acceptedAnswer":{"@type":"Answer","text":"Whoza.ai costs £59 per month. That's less than one small roof repair. Most roofers miss 3-5 high-value calls per day during storm season. At £1,200 average per storm repair, one recovered job per month pays for the entire year. The 7-day free trial lets you test with zero risk."}},{"@type":"Question","name":"Can AI handle roofing emergency calls properly?","acceptedAnswer":{"@type":"Answer","text":"Yes. Katie asks the right questions: what type of roof, what damage, is it leaking now, property postcode, and contact details. She flags urgent calls and sends everything to your WhatsApp within 3 seconds. For active leaks and storm damage, you can call back within minutes instead of hours."}},{"@type":"Question","name":"Do customers trust AI for roofing quotes?","acceptedAnswer":{"@type":"Answer","text":"Katie doesn't give quotes — she captures details and arranges a survey. Customers appreciate the immediate response and professional follow-up. Most just want someone to acknowledge their call and book a visit. Katie does that instantly while you're on the roof."}},{"@type":"Question","name":"What about complex roofing jobs like insurance claims?","acceptedAnswer":{"@type":"Answer","text":"Katie captures all the key details: insurance company (if mentioned), damage extent, photos requested, and preferred survey times. She sends you a structured summary so you can handle the insurance process properly. Nothing gets lost in translation."}},{"@type":"Question","name":"Is the 7-day trial actually free?","acceptedAnswer":{"@type":"Answer","text":"Yes. No credit card. No contract. Full access for 7 days. I signed up because I had nothing to lose. Captured a £450 job on Day 1 and a £7,500 re-roof lead by Day 3. Best business decision I made this year."}}]}13:["$","div",null,{"className":"min-h-screen bg-[var(--navy-900)] text-white","children":[["$","$L1d",null,{}],["$","script",null,{"id":"blog-post-article-schema","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"I Lost an £8,000 Roof Job Because I Was Up a Ladder. AI Fixed That.\",\"description\":\"Self-employed roofer from Manchester shares his honest 5-week diary using AI call answering. Real numbers. Storm damage season. £9,400 in recovered jobs.\",\"image\":\"https://whoza.ai/og-image.webp\",\"datePublished\":\"2026-06-17\",\"dateModified\":\"2026-06-17\",\"author\":{\"@type\":\"Person\",\"name\":\"Mike Harrison\",\"jobTitle\":\"Self-Employed Roofer, Manchester\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Whoza.ai\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://whoza.ai/og-image.webp\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://whoza.ai/blog/i-lost-a-8000-roof-job-because-i-was-up-a-ladder-mike-the-roofer\"},\"articleSection\":\"UGC / Real Stories\",\"wordCount\":1998,\"inLanguage\":\"en-GB\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\"article h1\",\"article h2\",\"article p\"]}}"}}],null,["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1e"}}],["$","$L1f",null,{"items":[{"name":"Home","item":"https://whoza.ai"},{"name":"Blog","item":"https://whoza.ai/blog"},{"name":"I Lost an £8,000 Roof Job Because I Was Up a Ladder. AI Fixed That.","item":"https://whoza.ai/blog/i-lost-a-8000-roof-job-because-i-was-up-a-ladder-mike-the-roofer"}]}],"$L20","$L21"]}]
