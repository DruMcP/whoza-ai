37:["$","details","3",{"className":"group bg-white/5 border border-white/10 rounded-xl open:border-emerald-500/30 open:bg-emerald-500/[0.03] transition-all","children":[["$","summary",null,{"className":"flex items-center justify-between p-6 cursor-pointer list-none","children":[["$","span",null,{"className":"font-semibold text-white pr-4","children":"Does Clara AI deliver calls via WhatsApp?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 group-open:rotate-180 transition-transform","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-6 pb-6 text-white/70 leading-relaxed","children":"No, Clara AI delivers call notifications via email only. This is a major limitation for UK tradespeople, as 85% of UK adults use WhatsApp and trade business owners check messaging apps 4.2x more frequently than email during work hours. whoza.ai, Team-Connect, and Smith.ai offer WhatsApp or SMS delivery alternatives."}]]}]
38:["$","details","4",{"className":"group bg-white/5 border border-white/10 rounded-xl open:border-emerald-500/30 open:bg-emerald-500/[0.03] transition-all","children":[["$","summary",null,{"className":"flex items-center justify-between p-6 cursor-pointer list-none","children":[["$","span",null,{"className":"font-semibold text-white pr-4","children":"Which AI answering service has the shortest contract?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 group-open:rotate-180 transition-transform","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-6 pb-6 text-white/70 leading-relaxed","children":"whoza.ai and Team-Connect both offer no-contract, cancel-anytime service. Clara AI requires a 3-month minimum commitment. Moneypenny typically requires 12-month contracts. Smith.ai offers monthly options but at US pricing. For tradespeople who want flexibility, whoza.ai offers the best combination of no contract plus a 30-day money-back guarantee."}]]}]
39:["$","details","5",{"className":"group bg-white/5 border border-white/10 rounded-xl open:border-emerald-500/30 open:bg-emerald-500/[0.03] transition-all","children":[["$","summary",null,{"className":"flex items-center justify-between p-6 cursor-pointer list-none","children":[["$","span",null,{"className":"font-semibold text-white pr-4","children":"Can AI phone answering services collect Google reviews?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 group-open:rotate-180 transition-transform","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-6 pb-6 text-white/70 leading-relaxed","children":"Only whoza.ai includes built-in Google review collection as a standard feature (via Claire, the review engine). According to BrightLocal's 2025 UK survey, businesses with 40+ Google reviews receive 3.5x more enquiries. None of the other services tested — Clara AI, Moneypenny, Team-Connect, or Smith.ai — include review collection. If reviews matter to your business (and they should), whoza.ai is the clear choice."}]]}]
3a:["$","details","6",{"className":"group bg-white/5 border border-white/10 rounded-xl open:border-emerald-500/30 open:bg-emerald-500/[0.03] transition-all","children":[["$","summary",null,{"className":"flex items-center justify-between p-6 cursor-pointer list-none","children":[["$","span",null,{"className":"font-semibold text-white pr-4","children":"Which is cheaper: whoza.ai or Clara AI?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 group-open:rotate-180 transition-transform","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-6 pb-6 text-white/70 leading-relaxed","children":"Clara AI is cheaper at entry level: £49.99/month vs whoza.ai's £59/month. However, Clara requires a 3-month minimum (£149.97 upfront) while whoza.ai has no contract. At mid-tier, Clara Pro (£99.99) is cheaper than whoza.ai Growth (£125), but Clara Pro lacks WhatsApp delivery, review collection, and competitor analysis — features included in whoza.ai Growth. For trades who need more than basic call answering, whoza.ai offers better overall value despite the slightly higher price."}]]}]
3b:["$","details","7",{"className":"group bg-white/5 border border-white/10 rounded-xl open:border-emerald-500/30 open:bg-emerald-500/[0.03] transition-all","children":[["$","summary",null,{"className":"flex items-center justify-between p-6 cursor-pointer list-none","children":[["$","span",null,{"className":"font-semibold text-white pr-4","children":"Do AI call handlers work for plumbers and electricians?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 group-open:rotate-180 transition-transform","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-6 pb-6 text-white/70 leading-relaxed","children":"Yes, AI call handlers work excellently for plumbers, electricians, and all UK trades. Modern AI is trained on trade-specific terminology — it understands 'combi boiler', 'consumer unit', 'emergency lockout', and 'drainage clearance'. whoza.ai supports 15+ trades with custom training. Clara AI handles general trades well. The key is choosing a service that offers trade-specific training rather than generic call answering. All five services tested handle routine trade enquiries competently."}]]}]
3c:["$","details","8",{"className":"group bg-white/5 border border-white/10 rounded-xl open:border-emerald-500/30 open:bg-emerald-500/[0.03] transition-all","children":[["$","summary",null,{"className":"flex items-center justify-between p-6 cursor-pointer list-none","children":[["$","span",null,{"className":"font-semibold text-white pr-4","children":"How quickly can I set up an AI phone answering service?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 group-open:rotate-180 transition-transform","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-6 pb-6 text-white/70 leading-relaxed","children":"whoza.ai has the fastest setup at 30 minutes — connect your number via call forwarding, fill in your services and hours, test with a sample call, and go live. Clara AI takes 2–4 hours including a mandatory AI training period. Team-Connect sets up in under an hour. Moneypenny requires 2–5 days for human receptionist onboarding. Smith.ai takes 1–2 days. If you need to be live today, whoza.ai is the fastest option."}]]}]
