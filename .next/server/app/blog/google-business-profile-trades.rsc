1e:T8b4,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much does Google Business Profile cost?","acceptedAnswer":{"@type":"Answer","text":"Google Business Profile is completely free. There are no setup costs, no monthly fees, and no charges for clicks or calls. Google provides this service because it helps them provide better local search results. The only cost is your time to optimise and maintain it."}},{"@type":"Question","name":"How long does it take to rank in Google Maps?","acceptedAnswer":{"@type":"Answer","text":"A well-optimised GBP can start appearing in local search within 2-4 weeks. Breaking into the top 3 map pack typically takes 3-6 months of consistent work (reviews, posts, photos, citations). Dominating your local market usually takes 6-12 months. The key factors are review velocity, profile completeness, and local relevance."}},{"@type":"Question","name":"Can I have multiple Google Business Profiles for different areas?","acceptedAnswer":{"@type":"Answer","text":"Google generally allows one profile per physical location. If you have a shopfront, that's your profile location. If you're mobile and serve multiple areas, use the service areas feature to list all the towns you cover. Don't create fake profiles for areas where you don't have a genuine presence — Google will suspend them."}},{"@type":"Question","name":"What should I do if my GBP gets suspended?","acceptedAnswer":{"@type":"Answer","text":"GBP suspensions usually happen for one of three reasons: keyword stuffing in your business name, fake reviews, or a mismatch between your address and Google's records. Read the suspension email carefully, fix the issue, and submit a reinstatement request through Google Business Profile Help. The process typically takes 2-5 business days."}},{"@type":"Question","name":"How many photos should I upload to my GBP?","acceptedAnswer":{"@type":"Answer","text":"Aim for 10-15 photos during initial setup, then add 2-3 new photos every week. Businesses with 50+ photos get significantly more engagement than those with fewer. The key is recency — upload new photos regularly to signal that your business is active. Google rewards fresh content."}}]}13:["$","div",null,{"className":"min-h-screen bg-[var(--navy-900)] text-white","children":[["$","$L1d",null,{}],["$","script",null,{"id":"blog-post-article-schema","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"Google Business Profile for Trades: The Complete Optimisation Guide\",\"description\":\"Your Google Business Profile is your most powerful marketing tool. Learn how to optimise it properly to rank higher, get more calls, and win more customers.\",\"image\":\"https://whoza.ai/og-image.webp\",\"datePublished\":\"2026-06-05\",\"dateModified\":\"2026-06-05\",\"author\":{\"@type\":\"Person\",\"name\":\"Dru McPherson\",\"jobTitle\":\"Founder, whoza.ai\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Whoza.ai\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://whoza.ai/og-image.webp\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://whoza.ai/blog/google-business-profile-trades\"},\"articleSection\":\"Trade Business Tips\",\"wordCount\":2731,\"inLanguage\":\"en-GB\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\"article h1\",\"article h2\",\"article p\"]}}"}}],null,["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1e"}}],"$L1f","$L20","$L21"]}]
