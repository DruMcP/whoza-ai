2a:["$","div",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-bold text-white mb-6","children":"Frequently Asked Questions"}],["$","div",null,{"className":"space-y-4","children":[["$","div","faq-0",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"How do builders generate the best quality leads?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"The highest-quality builder leads come from architect referrals, estate agent recommendations, and Google searches for specific project types ('loft conversion specialist', 'extension builder'). These leads have researched budgets, clear timelines, and higher conversion rates than generic 'builder near me' searches."}]]}],["$","div","faq-1",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"What percentage of builder enquiries convert to jobs?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Builder enquiry-to-quote conversion is 50-70% (site survey booking). Quote-to-job conversion is 25-40% depending on pricing, portfolio quality, and follow-up discipline. The average builder needs 3-4 enquiries to win one job. Missing enquiries is the biggest leak in the conversion funnel."}]]}],["$","div","faq-2",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"How quickly should builders respond to enquiries?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Within 15 minutes for maximum conversion impact. Research shows 78% of customers hire the first responder. AI call handling delivers enquiries to WhatsApp in 3 seconds, enabling immediate callback even when you're on site."}]]}],["$","div","faq-3",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"Should builders advertise on Google or Facebook?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Google Ads targeting specific project keywords ('loft conversion Bristol', 'kitchen extension Manchester') can generate qualified leads at £40-£80 per enquiry. Facebook ads are less effective for builders as the intent is lower. Prioritise Google Business Profile optimisation and local SEO before paid advertising."}]]}],["$","div","faq-4",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"How does AI call handling help builders specifically?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"AI captures every missed builder enquiry with full project details: scope, budget, timeline, planning permission status, and architect involvement. Commercial and insurance enquiries get automatic priority flagging. Details arrive via WhatsApp in 3 seconds for immediate, informed callback."}]]}]]}]]}]
