ading-relaxed mb-6","children":"Voicemail at 7 AM: \"It's Pat from Didsbury. Our boiler's gone completely. Three kids under ten, no heating, no hot water. I've called four engineers and you're the only one who didn't answer.\""}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":"I called back at 7:15. She'd already booked someone else. £280 callout plus a new pump. Total job value: £650. Gone. Because I was asleep."}],"$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43","$L44","$L45","$L46","$L47","$L48","$L49","$L4a","$L4b","$L4c","$L4d","$L4e"]}]}]]}]
18:["$","$L4f",null,{}]
