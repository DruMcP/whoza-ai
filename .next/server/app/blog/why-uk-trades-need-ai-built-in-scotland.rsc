2a:["$","section","section-7",{"className":"mb-10","children":[["$","h3",null,{"className":"text-xl font-semibold text-white mb-3 mt-6","children":"Where are my call recordings stored?"}],["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-4","dangerouslySetInnerHTML":{"__html":"We do not store audio recordings — we store text transcripts only. All data is processed and stored in UK data centres. GDPR compliant."}}],"$undefined","$undefined","$undefined"]}]
2b:["$","section","section-8",{"className":"mb-10","children":[["$","h3",null,{"className":"text-xl font-semibold text-white mb-3 mt-6","children":"Does whoza.ai work outside the UK?"}],["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-4","dangerouslySetInnerHTML":{"__html":"whoza.ai is specifically designed for UK tradespeople — British accents, UK postcodes, GBP pricing, VAT included. We focus on doing one market exceptionally well."}}],"$undefined","$undefined","$undefined"]}]
2c:["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-8 mb-10","children":["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line","dangerouslySetInnerHTML":{"__html":"A Scotland-built AI call handler is not about patriotism. It is about practical advantages that matter to your business: accurate postcode recognition, familiar voices, UK data protection, local support hours, and transparent pricing.\n\nWhen your customer calls about a burst pipe in Bristol, you want an AI that knows where Bristol is. When your customer speaks with a Scottish accent, you want an AI that understands them. When your customer data is sensitive, you want it protected by UK law.\n\nBuilt in Scotland. Working for UK trades."}}]}]
