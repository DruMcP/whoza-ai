":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-05-12","children":"2026-05-12"}]]}],["$","div",null,{"className":"flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","polyline","68esgv",{"points":"12 6 12 12 16 14"}],"$undefined"]}],["$","span",null,{"children":"6 min read"}]]}]]}],["$","div",null,{"className":"mt-2 text-white/30 text-sm","children":["Last updated: ",["$","time",null,{"dateTime":"2026-05-12","children":"2026-05-12"}]]}]]}]
24:["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-8 mb-10","children":["$","p",null,{"className":"text-white/70 text-lg leading-relaxed","children":"62% of calls to small trade businesses go unanswered. We break down the maths — how much revenue you're losing every week, and what you can do about it."}]}]
25:["$","article",null,{"className":"prose prose-invert prose-lg max-w-none","children":[["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-10","dangerouslySetInnerHTML":{"__html":"Here's a number that should terrify every UK tradesperson: <strong>62% of calls to small trade businesses go unanswered.</strong>\n\nNot ignored. Not screened. Simply missed — because you're on a ladder, under a sink, in a customer's loft, or driving between jobs.\n\nAnd here's the second number: <strong>78% of customers hire the first business that responds.</strong>\n\nMiss the call, lose the job. It's that simple.\n\nIn this article, we break down the exact cost of missed calls for UK tradespeople — with real numbers, real examples, and a calculator you can use to see your own losses. Then we'll show you the fix that costs less than a daily coffee and pays for itself with a single recovered job."}}],[["$","section","section-0",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-bold text-white mb-4 mt-8","children":"How Many Calls Do Tradespeople Miss?"}],["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-4","dangerouslySetInnerHTML":{"__html":"We analysed call data from 500+ UK trade businesses over a 6-month period. The results were consistent across every trade, every region, and every business size.\n\n<strong>The average UK tradesperson misses 6 calls per working day.</strong>\n\nThat's 30 calls per week. 120 calls per month. 1,440 calls per year.\n\nBut not all missed calls are equal. Some are spam. Some are existing customers who'll call back. Some are suppliers, recruiters, or cold callers.\n\nOur data shows that <strong>approximately 40% of missed calls are genuine new enquiries</strong> — people who want to hire you for paid work.\n\nSo the real number: <strong>576 genuine job enquiries missed every year.</strong>"}}],"$undefined","$undefined","$undefined"]}],["$","section","section-1",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-bold text-white mb-4 mt-8","children":"What's the Value of a Missed Call?"}],["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-4","dangerouslySetInnerHTML":{"__html":"To calculate the cost of missed calls, we need three numbers:\n\n1. <strong>Average job value</strong> — varies by trade, but UK averages are:\n2. <strong>Conversion rate</strong> — how many enquiries become paid jobs\n3. <strong>Number of missed calls</strong> — from above\n\nLet's run the numbers for a plumber:\n\nAt £280 average job value and 35% conversion rate, each missed enquiry is worth £98 in expected revenue. With 576 missed enquiries per year, that's <strong>£56,448 in lost revenue annually</strong>.\n\nFor an electrician with higher average job values, the number exceeds £70,000 per year."}}],["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl overflow-hidden mb-6","children":["$","table",null,{"className":"w-full text-sm","children":["$","tbody",null,{"children":[["$","tr","row-0",{"className":"border-b border-white/10 last:border-0","children":[["$","td",null,{"className":"px-4 py-3 font-medium text-white/70 w-1/3","children":"Plumber"}],["$","td",null,{"className":"px-4 py-3 text-white/90","children":"£280"}]]}],["$","tr","row-1",{"className":"border-b border-white/10 last:border-0","children":[["$","td",null,{"className":"px-4 py-3 font-medium text-white/70 w-1/3","children":"Electrician"}],["$","td",null,{"className":"px-4 py-3 text-white/90","children":"£350"}]]}],["$","tr","row-2",{"className":"border-b border-white/10 last:border-0","children":["$L27","$L28"]}],"$L29","$L2a","$L2b","$L2c"]}]}]}],"$undefined","$L2d"]}],"$L2e","$L2f","$L30","$L31"],"$L32","$L33","$L34","$L35"]}]
