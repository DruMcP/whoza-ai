4f:["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":[["$","strong",null,{"className":"text-white","children":"March-May: £420K lost"}]," (78% of annual losses)"]}]
50:["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":["Landscapers experience a compressed season. 78% of annual losses happen in the 12-week spring period when homeowners rush to book garden work. One landscaper ",["$","a",null,{"href":"/blog/i-missed-spring-booking-season-ai-captured-47-calls-in-3-weeks-james-the-landscaper","className":"text-[var(--katie-blue)] hover:underline","children":"missed the entire spring booking season"}]," before implementing AI."]}]
