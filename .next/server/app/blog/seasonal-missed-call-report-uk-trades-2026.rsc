5b:["$","h2",null,{"id":"regional","className":"text-2xl sm:text-3xl font-bold text-white mt-12 mb-6","children":"Regional Variations"}]
5c:["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":"Where you work affects how much you lose:"}]
5d:["$","ul",null,{"className":"list-disc list-inside text-white/70 space-y-2 mb-6","children":[["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"London:"}]," Highest per-call value (£420 average) but lowest missed call rate (58%). More competition means faster callback expectations."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"Manchester:"}]," Highest missed call rate (71%) due to weather-driven emergency demand. Winter losses 34% above national average."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"Birmingham:"}]," Balanced profile. 64% missed call rate, £380 average job value."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"Glasgow:"}]," Highest winter concentration — 78% of annual losses in Dec-Feb. Colder climate = more boiler emergencies."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"Rural areas:"}]," Fewer total calls but higher conversion rates (42% vs 28% in cities). One missed call matters more."]}]]}]
