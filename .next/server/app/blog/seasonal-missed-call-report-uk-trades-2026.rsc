49:["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":[["$","strong",null,{"className":"text-white","children":"Annual: £890K lost"}]," (89% after hours)"]}]
4a:["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":"Locksmiths have a unique problem: 89% of their missed calls happen outside normal working hours. Lockouts don't respect business hours. A single missed 2 AM lockout call costs £85-150. But locksmiths need sleep too."}]
4b:["$","h3",null,{"className":"text-xl font-bold text-white mt-8 mb-4","children":"Electricians: The Maintenance Cycle"}]
4c:["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":[["$","strong",null,{"className":"text-white","children":"Annual: £650K lost"}]," (steady, predictable)"]}]
4d:["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":["Electricians show the most predictable pattern. EICR (Electrical Installation Condition Report) work is scheduled, but emergency calls (power outages, faulty wiring) spike during storms. One electrician ",["$","a",null,{"href":"/blog/i-lost-3-emergency-callouts-a-day-heres-how-i-fixed-it-dave-the-sparky","className":"text-[var(--katie-blue)] hover:underline","children":"lost 3 emergency callouts a day"}]," before AI call answering."]}]
