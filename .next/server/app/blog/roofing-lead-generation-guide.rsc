29:["$","div",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-bold text-white mb-6","children":"Frequently Asked Questions"}],["$","div",null,{"className":"space-y-4","children":[["$","div","faq-0",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"What's the best lead generation channel for UK roofers?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Phone calls from Google Business Profile convert highest for roofers. 76% of local searchers call directly from Google. Emergency calls (storm damage, leaks) convert at 70-85%, making phone responsiveness the single biggest competitive advantage."}]]}],["$","div","faq-1",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"How much do roofers lose from missed calls?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"The average roofer misses 4-6 calls daily. With average repair values of £450-£800 and re-roofs at £8,000-£25,000, missing just 2 emergency calls per week costs £3,600-£6,400 monthly. During storm season, losses can exceed £10,000 per month."}]]}],["$","div","faq-2",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"How does AI call handling help roofers specifically?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"AI captures every missed call with roof-specific qualification: roof type, damage description, property age, insurance status, and photo availability. Emergency storm damage gets instant priority flagging. Details arrive via WhatsApp in 3 seconds for immediate action."}]]}],["$","div","faq-3",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"How can roofers get more Google reviews?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Ask every customer for a review via text within 24 hours of job completion. Include a direct Google review link. Offer to take before/after photos for the review. Aim for 2-3 reviews weekly. Reviews with photos increase conversion by 35%."}]]}],["$","div","faq-4",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"Should roofers use paid advertising?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Google Ads can work for roofers targeting emergency terms like 'emergency roofer near me' and 'storm damage repair.' But optimise your Google Business Profile and local SEO first — these free channels often generate better ROI. Use paid ads strategically during storm season."}]]}]]}]]}]
