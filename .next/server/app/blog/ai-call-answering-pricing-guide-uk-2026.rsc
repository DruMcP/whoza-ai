5a:["$","div",null,{"className":"bg-emerald-500/5 border border-emerald-500/20 rounded-xl p-6","children":[["$","h4",null,{"className":"font-semibold text-emerald-400 mb-3","children":"How We Calculate ROI"}],["$","p",null,{"className":"text-white/60 text-sm leading-relaxed mb-4","children":"Monthly ROI = (Average job value × Estimated extra jobs captured/month) – Monthly AI cost. We assume AI captures 8 extra qualified leads per month (conservative — based on 20 calls/week, 62% missed rate, 90% AI capture vs 22% voicemail capture, 35% conversion)."}],["$","div",null,{"className":"bg-slate-900/50 rounded-lg p-4 font-mono text-sm","children":[["$","p",null,{"className":"text-emerald-400","children":"Plumber Example:"}],["$","p",null,{"className":"text-white/70","children":"8 extra leads × 35% conversion = 2.8 extra jobs/month"}],["$","p",null,{"className":"text-white/70","children":"2.8 jobs × £280 = £784 extra revenue/month"}],["$","p",null,{"className":"text-white/70","children":["£784 revenue – £59 AI cost = ",["$","span",null,{"className":"text-emerald-400","children":"£725 net monthly gain"}]]}]]}]]}]
