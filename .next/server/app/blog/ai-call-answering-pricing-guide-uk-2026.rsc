5d:["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"font-bold text-white mb-3","children":"Builder — Recommended: Whoza.ai Growth (£125/month) or Enterprise (£249/month)"}],["$","p",null,{"className":"text-white/60 text-sm leading-relaxed mb-3","children":"Builders handle the most complex enquiries: extensions, renovations, new builds. Job values (£500–£60,000) justify premium AI with detailed qualification. Multi-van operations need team routing and job allocation. Enterprise plan supports multiple team members and project managers. One extension enquiry (£20,000+) covers 80+ months of service. Expected monthly ROI: £3,000–£8,000+."}],["$","div",null,{"className":"flex flex-wrap gap-2 text-xs","children":[["$","span",null,{"className":"bg-stone-500/10 text-stone-400 px-2 py-1 rounded-full","children":"Project detail"}],["$","span",null,{"className":"bg-stone-500/10 text-stone-400 px-2 py-1 rounded-full","children":"Multi-van teams"}],["$","span",null,{"className":"bg-stone-500/10 text-stone-400 px-2 py-1 rounded-full","children":"Highest totals"}]]}]]}]
5e:["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"font-bold text-white mb-2","children":"Does cheap AI answering actually work for trades?"}],["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"Cheap AI answering (£9–£30/month) typically uses basic auto-attendant or simple voice-menu technology, not true conversational AI. For tradespeople, this means callers get frustrated, hang up, or leave incomplete messages. True AI answering (£49–£125/month) uses natural language processing to have real conversations, ask trade-specific questions, and capture complete job details. The £40–£100 monthly difference often pays for itself with one extra captured job."}]]}]
