55:["$","div","5",{"className":"flex gap-4 bg-white/5 border border-white/10 rounded-xl p-5","children":[["$","div",null,{"className":"w-8 h-8 rounded-full bg-emerald-500/10 text-emerald-400 font-bold text-sm flex items-center justify-center shrink-0","children":"5"}],["$","div",null,{"children":[["$","h3",null,{"className":"font-semibold text-white mb-1","children":"WhatsApp Delivery (3 Seconds)"}],["$","p",null,{"className":"text-sm text-white/60","children":"The structured enquiry is delivered to your WhatsApp with a clean summary: [URGENCY] [TRADE] [NAME] [ADDRESS] [PHONE] [JOB DESCRIPTION]. Emergency alerts include a red header and urgent notification tone. whoza.ai delivers in 3 seconds — faster than any human service."}]]}]]}]
56:["$","div","6",{"className":"flex gap-4 bg-white/5 border border-white/10 rounded-xl p-5","children":[["$","div",null,{"className":"w-8 h-8 rounded-full bg-emerald-500/10 text-emerald-400 font-bold text-sm flex items-center justify-center shrink-0","children":"6"}],["$","div",null,{"children":[["$","h3",null,{"className":"font-semibold text-white mb-1","children":"Escalation (Optional)"}],["$","p",null,{"className":"text-sm text-white/60","children":"If you configure escalation, the AI sends a second alert after 15 minutes if the first has not been acknowledged. For critical emergencies, you can set up cascade alerts: first to you, then to your partner, then to your on-call engineer. This ensures no emergency is ever missed."}]]}]]}]
57:["$","div","7",{"className":"flex gap-4 bg-white/5 border border-white/10 rounded-xl p-5","children":[["$","div",null,{"className":"w-8 h-8 rounded-full bg-emerald-500/10 text-emerald-400 font-bold text-sm flex items-center justify-center shrink-0","children":"7"}],["$","div",null,{"children":[["$","h3",null,{"className":"font-semibold text-white mb-1","children":"Morning Summary"}],["$","p",null,{"className":"text-sm text-white/60","children":"At 7am, you receive a summary of all overnight calls: how many, which were emergencies, how many you have already responded to, and which still need attention. This gives you a complete picture before you even get out of bed."}]]}]]}]
58:["$","div",null,{"className":"flex-1","children":[["$","div",null,{"className":"flex items-center gap-3 mb-1","children":[["$","h3",null,{"className":"font-semibold text-white","children":"Set WhatsApp Delivery"}],["$","span",null,{"className":"text-xs text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full","children":"5 mins"}]]}],["$","p",null,{"className":"text-sm text-white/60","children":"Enter the mobile number where you want enquiry alerts delivered. This is usually your work phone. You can add up to 3 delivery numbers for team coverage. Test the delivery with a sample message."}]]}]
59:["$","div","5",{"className":"flex gap-4 bg-white/5 border border-white/10 rounded-xl p-5","children":[["$","div",null,{"className":"w-8 h-8 rounded-full bg-emerald-500/10 text-emerald-400 font-bold text-sm flex items-center justify-center shrink-0","children":"5"}],["$","div",null,{"className":"flex-1","children":[["$","div",null,{"className":"flex items-center gap-3 mb-1","children":[["$","h3",null,{"className":"font-semibold text-white","children":"Test & Go Live"}],["$","span",null,{"className":"text-xs text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full","children":"5 mins"}]]}],["$","p",null,{"className":"text-sm text-white/60","children":"Make a test call from a different number. Verify the AI answers correctly, asks the right questions, and delivers the enquiry to your WhatsApp within 3 seconds. Once verified, you are live. Total time: 30 minutes."}]]}]]}]
5a:["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Once live, the AI starts answering immediately. There is no training period, no warm-up phase, and no learning curve. You will receive your first real enquiry alert within hours, not days. And if you ever need to make changes — update your services, change your delivery number, or adjust your hours — the dashboard updates take effect in real time."}]
5b:["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"AI-powered 24/7 call answering costs £59–£399 per month depending on call volume. Human 24/7 answering services like Moneypenny charge £150–£400+/month. In-house receptionists cost £20,000–£25,000 per year plus holiday and sickness cover. For most sole traders, AI 24/7 answering at £59–£125/month delivers the best value with no contracts and instant setup."}]
5c:["$","details","3",{"className":"bg-white/5 border border-white/10 rounded-xl group","children":[["$","summary",null,{"className":"flex items-center justify-between p-5 cursor-pointer list-none","children":[["$","span",null,{"className":"font-medium text-white pr-4","children":"Can AI really handle emergency calls at 2am?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 transition-transform group-open:rotate-180","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-5 pb-5","children":["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"Yes, modern AI call answering handles emergency calls at 2am with the same accuracy as daytime calls. The AI recognises urgency keywords ('burst pipe', 'no heating', 'locked out'), asks trade-specific questions, captures the caller's location and contact details, and delivers the lead to your WhatsApp within 3 seconds. It never sleeps, never takes holidays, and answers every call on the first ring."}]}]]}]
5d:["$","details","4",{"className":"bg-white/5 border border-white/10 rounded-xl group","children":[["$","summary",null,{"className":"flex items-center justify-between p-5 cursor-pointer list-none","children":[["$","span",null,{"className":"font-medium text-white pr-4","children":"What happens during out-of-hours with AI call answering?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 transition-transform group-open:rotate-180","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-5 pb-5","children":["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"During out-of-hours, the AI answers the call immediately, identifies the trade and urgency level, captures the caller's name, address, phone number, and job description, tags the enquiry by priority (emergency vs routine), and delivers everything to your WhatsApp with a structured summary. For emergencies, you can configure escalation — the AI sends an urgent WhatsApp alert and can trigger a second notification if the call is not acknowledged within 15 minutes."}]}]]}]
5e:["$","details","5",{"className":"bg-white/5 border border-white/10 rounded-xl group","children":[["$","summary",null,{"className":"flex items-center justify-between p-5 cursor-pointer list-none","children":[["$","span",null,{"className":"font-medium text-white pr-4","children":"How does AI 24/7 answering compare to Moneypenny or Answer.co.uk?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 transition-transform group-open:rotate-180","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-5 pb-5","children":["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"AI 24/7 answering costs 60–85% less than human services (£59 vs £150+/month), sets up in 30 minutes vs 2–5 days, and delivers to WhatsApp in 3 seconds. Moneypenny offers human empathy and complex enquiry handling but requires 12-month contracts and costs significantly more. Answer.co.uk provides UK-based agents but lacks WhatsApp delivery and review collection. AI wins on speed, cost, and availability; human services win on empathy and complex cases."}]}]]}]
5f:["$","details","6",{"className":"bg-white/5 border border-white/10 rounded-xl group","children":[["$","summary",null,{"className":"flex items-center justify-between p-5 cursor-pointer list-none","children":[["$","span",null,{"className":"font-medium text-white pr-4","children":"How many emergency jobs justify paying for 24/7 call answering?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 transition-transform group-open:rotate-180","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-5 pb-5","children":["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"At £59/month for AI 24/7 answering, you only need to capture one emergency job every 2–3 months to break even. At an average emergency job value of £180–£400, a single burst pipe callout at 2am pays for 3–7 months of service. Most trades who switch to 24/7 answering report capturing 2–5 additional emergency jobs per month — generating £360–£2,000 in extra monthly revenue for a £59–£125 investment."}]}]]}]
60:["$","details","7",{"className":"bg-white/5 border border-white/10 rounded-xl group","children":[["$","summary",null,{"className":"flex items-center justify-between p-5 cursor-pointer list-none","children":[["$","span",null,{"className":"font-medium text-white pr-4","children":"Does AI call answering work on bank holidays and Christmas?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 transition-transform group-open:rotate-180","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-5 pb-5","children":["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"Yes, AI call answering operates 365 days a year including bank holidays, Christmas Day, New Year's Day, and Easter Sunday. Unlike human receptionists who take holiday leave, AI never takes a day off. This is critical for emergency trades — boiler failures and lockouts do not wait for Boxing Day. Holiday coverage is included at no extra cost with AI services like whoza.ai."}]}]]}]
61:["$","details","8",{"className":"bg-white/5 border border-white/10 rounded-xl group","children":[["$","summary",null,{"className":"flex items-center justify-between p-5 cursor-pointer list-none","children":[["$","span",null,{"className":"font-medium text-white pr-4","children":"How quickly can I set up 24/7 AI call answering?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 transition-transform group-open:rotate-180","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-5 pb-5","children":["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"You can set up 24/7 AI call answering in approximately 30 minutes. The process is: connect your business number via call forwarding, configure your trade profile and services, set your WhatsApp delivery number, test with a sample call, and go live. No hardware, software, or technical knowledge is required. whoza.ai offers guided setup and live support to ensure you're capturing calls within the hour."}]}]]}]
62:["$","details","9",{"className":"bg-white/5 border border-white/10 rounded-xl group","children":[["$","summary",null,{"className":"flex items-center justify-between p-5 cursor-pointer list-none","children":[["$","span",null,{"className":"font-medium text-white pr-4","children":"Is whoza.ai ICO registered for 24/7 call answering?"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down w-5 h-5 text-white/40 shrink-0 transition-transform group-open:rotate-180","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","div",null,{"className":"px-5 pb-5","children":["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"Yes, whoza.ai is registered with the Information Commissioner's Office (ICO) under registration number ZC077271, ensuring full compliance with UK GDPR and data protection laws. whoza.ai is also a registered Scottish company (Company Number SC874716). All call data is encrypted, stored securely, and processed in accordance with UK data protection regulations. You can verify ICO registration at ico.org.uk."}]}]]}]
