51:["$","div",null,{"className":"bg-amber-500/5 border border-amber-500/20 rounded-xl p-6 mb-6","children":[["$","h3",null,{"className":"font-semibold text-amber-400 mb-3 flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chart-column w-5 h-5","children":[["$","path","c24i48",{"d":"M3 3v16a2 2 0 0 0 2 2h16"}],["$","path","2bz60n",{"d":"M18 17V9"}],["$","path","1frdt8",{"d":"M13 17V5"}],["$","path","17ska0",{"d":"M8 17v-3"}],"$undefined"]}],"The Hidden Costs of In-House Reception"]}],["$","p",null,{"className":"text-white/70 text-sm leading-relaxed mb-4","children":"A full-time receptionist at £20,000/year sounds straightforward until you add the real costs: Employer National Insurance (£2,200), pension contributions (£600), holiday cover (8.4 weeks at agency rates), sick days (6.5 days average), training time, desk space, and equipment. The true cost of an in-house receptionist is £25,000–£28,000 per year. And they still go home at 5pm, take weekends off, and book holidays in July when you are at your busiest."}],["$","p",null,{"className":"text-white/70 text-sm leading-relaxed","children":["AI 24/7 answering at ",["$","a",null,{"href":"/pricing","className":"text-emerald-400 hover:underline","children":"our pricing"}]," (£59–£125/month, £708–£1,500/year) delivers 99.97% uptime, never takes a holiday, and answers calls at 2am on Christmas morning. For most trade businesses, the economics are not even close."]}]]}]
52:["$","p",null,{"className":"text-sm text-white/70","children":"AI answers on first ring. Confirms lockout, captures address and phone number, confirms tenant is authorised (checks ID on arrival). WhatsApp delivered instantly. Locksmith attends within 25 minutes. Emergency callout: £195. Lock rekeying: £65. Total: £260."}]
53:["$","div","Boiler Failure on Sunday Morning",{"className":"bg-white/5 border border-white/10 rounded-xl overflow-hidden","children":[["$","div",null,{"className":"bg-white/5 px-6 py-3 border-b border-white/10 flex items-center gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-moon w-4 h-4 text-emerald-400","children":[["$","path","a7tn18",{"d":"M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"}],"$undefined"]}],["$","span",null,{"className":"text-sm font-medium text-white/80","children":"6:22am, Sunday, December"}],["$","span",null,{"className":"text-white/20","children":"|"}],["$","span",null,{"className":"text-sm text-amber-400","children":"Boiler Failure on Sunday Morning"}]]}],["$","div",null,{"className":"p-6 grid sm:grid-cols-2 gap-6","children":[["$","div",null,{"children":[["$","h4",null,{"className":"text-sm font-semibold text-red-400 mb-2","children":"Without 24/7 Answering"}],["$","p",null,{"className":"text-sm text-white/50","children":"Voicemail left at 6:22am. Engineer checks messages at 8:45am. By then, caller has contacted gas company emergency line and booked their contractor. Job lost."}]]}],["$","div",null,{"children":[["$","h4",null,{"className":"text-sm font-semibold text-emerald-400 mb-2","children":"With AI 24/7 Answering"}],["$","p",null,{"className":"text-sm text-white/70","children":"AI answers, identifies no heating + elderly occupants, tags as PRIORITY EMERGENCY. WhatsApp alert includes 'ELDERLY — NO HEAT — SUBZERO'. Engineer sees alert at 7:00am, calls immediately. Attends within 1 hour. Diagnosis: faulty PCB. Replacement part: £340. Labour: £180. Callout: £220. Total: £740."}]]}]]}]]}]
