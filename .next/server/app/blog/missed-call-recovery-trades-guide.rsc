46:["$","div","faq-6",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"Can I recover revenue from old missed calls?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Yes, but with diminishing returns. Call back missed calls from the past 24-48 hours for the best chance of recovery. After 1 week, most customers have hired someone else. After 1 month, recovery is nearly impossible. The key is preventing future misses, not recovering past ones."}]]}]
47:["$","div","faq-7",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"What is the complete system for never missing a call?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"The complete system has five layers: AI call answering for capture, WhatsApp action buttons for instant response, rapid response protocol for answered calls, follow-up discipline for non-converters, and review requests for completed jobs. Together, these layers turn missed calls into a revenue engine."}]]}]
