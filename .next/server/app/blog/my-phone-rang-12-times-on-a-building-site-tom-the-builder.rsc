ite/5 border border-white/10 rounded-xl p-8 mb-10","children":["$","p",null,{"className":"text-white/70 text-lg leading-relaxed","children":"Self-employed builder from Birmingham shares his honest 4-week diary using AI call answering. Real numbers. Extensions, renovations, emergency callouts. £7,200 in recovered jobs."}]}],["$","article",null,{"className":"prose prose-invert prose-lg max-w-none","children":[["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-10","dangerouslySetInnerHTML":{"__html":"$23"}}],["$L24","$L25","$L26","$L27","$L28","$L29","$L2a"],"$L2b","$L2c","$L2d","$L2e"]}]]}]
