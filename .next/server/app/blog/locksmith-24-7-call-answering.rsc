w-4 h-4","children":[["$","path","975kel",{"d":"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"}],["$","circle","17ys0d",{"cx":"12","cy":"7","r":"4"}],"$undefined"]}],["$","span",null,{"children":"Dru McPherson"}],["$","span",null,{"className":"text-white/30","children":["— ","Founder, whoza.ai"]}]]}],["$","div",null,{"className":"flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-calendar w-4 h-4","children":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-06-05","children":"2026-06-05"}]]}],["$","div",null,{"className":"flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","polyline","68esgv",{"points":"12 6 12 12 16 14"}],"$undefined"]}],["$","span",null,{"children":"7 min read"}]]}]]}],["$","div",null,{"className":"mt-2 text-white/30 text-sm","children":["Last updated: ",["$","time",null,{"dateTime":"2026-06-05","children":"2026-06-05"}]]}]]}],["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-8 mb-10","children":["$","p",null,{"className":"text-white/70 text-lg leading-relaxed","children":"Lockouts are the most urgent trade calls. Learn how UK locksmiths can capture emergency lockout enquiries 24/7, prioritise high-value security upgrades, and convert after-hours calls into booked jobs."}]}],["$","article",null,{"className":"prose prose-invert prose-lg max-w-none","children":[["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-10","dangerouslySetInnerHTML":{"__html":"A lockout at 11pm is not a tomorrow problem. It's a right-now problem. The customer is standing outside their home in the rain, their phone battery is dying, and they're calling every locksmith on Google until someone answers.\n\nLocksmiths operate in the most time-sensitive environment of any UK trade. A customer locked out won't wait 10 minutes for a callback — they'll have hired someone else by then. And the jobs that come at 2am, Sunday afternoon, or bank holiday Monday are often the most profitable — because competitors are closed.\n\nThis guide covers how UK locksmiths can implement 24/7 call answering to capture every lockout, security upgrade, and key replacement enquiry, regardless of when it comes in."}}],["$L24","$L25","$L26","$L27"],"$L28","$L29","$L2a","$L2b"]}]]}]
