 w-4 h-4","children":[["$","path","975kel",{"d":"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"}],["$","circle","17ys0d",{"cx":"12","cy":"7","r":"4"}],"$undefined"]}],["$","span",null,{"children":"Mark Henderson"}],["$","span",null,{"className":"text-white/30","children":["— ","Self-Employed Heating Engineer, Leeds"]}]]}],["$","div",null,{"className":"flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-calendar w-4 h-4","children":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-06-08","children":"2026-06-08"}]]}],["$","div",null,{"className":"flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","polyline","68esgv",{"points":"12 6 12 12 16 14"}],"$undefined"]}],["$","span",null,{"children":"8 min read"}]]}]]}],["$","div",null,{"className":"mt-2 text-white/30 text-sm","children":["Last updated: ",["$","time",null,{"dateTime":"2026-06-08","children":"2026-06-08"}]]}]]}],["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-8 mb-10","children":["$","p",null,{"className":"text-white/70 text-lg leading-relaxed","children":"Self-employed heating engineer from Leeds reveals the 5 warning signs that cost him £18,000 a year. Number 3 made me sick when I worked it out."}]}],["$","article",null,{"className":"prose prose-invert prose-lg max-w-none","children":[["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-10","dangerouslySetInnerHTML":{"__html":"I am Mark. I fix boilers and install heating systems in Leeds and surrounding areas. 14 years on the tools. Van full of parts. No receptionist. Just me, my phone, and a problem I did not see coming until it was too late.\n\nLast year I worked out I was losing £18,000 to missed calls. Not because I am lazy. Not because I do not care. Because I was under floors, in lofts, inside boiler cupboards, and my phone was in my pocket vibrating against a pipe I could not reach.\n\nHere are the 5 signs I wish I had spotted earlier. If you recognise even one, you are bleeding money every single day."}}],["$L23","$L24","$L25","$L26","$L27"],"$L28","$L29","$L2a","$L2b"]}]]}]
