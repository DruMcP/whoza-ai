ser w-4 h-4","children":[["$","path","975kel",{"d":"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"}],["$","circle","17ys0d",{"cx":"12","cy":"7","r":"4"}],"$undefined"]}],["$","span",null,{"children":"Sarah Jenkins"}],["$","span",null,{"className":"text-white/30","children":["— ","Self-Employed Locksmith, Leeds"]}]]}],["$","div",null,{"className":"flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-calendar w-4 h-4","children":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-06-07","children":"2026-06-07"}]]}],["$","div",null,{"className":"flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","polyline","68esgv",{"points":"12 6 12 12 16 14"}],"$undefined"]}],["$","span",null,{"children":"9 min read"}]]}]]}],["$","div",null,{"className":"mt-2 text-white/30 text-sm","children":["Last updated: ",["$","time",null,{"dateTime":"2026-06-07","children":"2026-06-07"}]]}]]}],["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-8 mb-10","children":["$","p",null,{"className":"text-white/70 text-lg leading-relaxed","children":"Self-employed locksmith from Leeds shares honest 3-week diary using AI call answering. Real numbers. No BS. Emergency lockouts, security upgrades, and after-hours calls. £4,800 recovered in 3 weeks."}]}],["$","article",null,{"className":"prose prose-invert prose-lg max-w-none","children":[["$","div",null,{"className":"text-white/80 leading-relaxed whitespace-pre-line mb-10","dangerouslySetInnerHTML":{"__html":"3 AM. Saturday. My phone rings. I sleep through it. Voicemail in the morning: \"Locked out of my house, it's freezing, I've got a baby.\" I call back at 8 AM. They've already paid someone else £180 at 4 AM.\n\nThat used to happen twice a week. Minimum. I worked out I was losing £800-£1,000 per month just to after-hours lockouts. People who called me first because I've got good reviews. But I was asleep. And they couldn't wait.\n\nI'm Sarah. Locksmith from Leeds. 7 years self-employed. Emergency lockouts, security upgrades, lock repairs, key cutting. Mobile van. And this is what happened when I let AI answer my phone while I was asleep."}}],["$L24","$L25","$L26","$L27","$L28","$L29","$L2a"],"$L2b","$L2c","$L2d","$L2e"]}]]}]
