1e:T7bc,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do callers know they're speaking to AI?","acceptedAnswer":{"@type":"Answer","text":"Modern AI call handlers use natural-sounding voices with realistic pauses and intonation. Most callers don't realise it's AI unless told. The focus is on helpful, efficient service — not disguising the technology."}},{"@type":"Question","name":"Can AI handle complex or unusual enquiries?","acceptedAnswer":{"@type":"Answer","text":"Yes. The AI is trained on thousands of trade business conversations and can handle everything from emergency calls to routine maintenance bookings. For truly complex situations, it can transfer to you or schedule a callback."}},{"@type":"Question","name":"What happens if the AI can't help the caller?","acceptedAnswer":{"@type":"Answer","text":"The AI escalates by offering to arrange a callback from you directly. The caller's details and enquiry summary are captured and sent to your WhatsApp so you can follow up personally."}},{"@type":"Question","name":"How long does setup take?","acceptedAnswer":{"@type":"Answer","text":"Most businesses are live within 30 minutes. You connect your existing phone number, set your business details and preferences, and the AI starts answering immediately. No hardware, no software installation."}},{"@type":"Question","name":"Will this work with my existing phone number?","acceptedAnswer":{"@type":"Answer","text":"Yes. whoza.ai connects to your existing business landline or mobile number. Your customers dial the same number they always have — the AI simply answers when you can't."}},{"@type":"Question","name":"How much does an AI call handler cost?","acceptedAnswer":{"@type":"Answer","text":"whoza.ai plans start at £59/month for the Starter plan, which includes unlimited calls and WhatsApp delivery. The Growth plan at £125/month adds team features and priority support. All plans include a 7-day free trial."}}]}13:["$","div",null,{"className":"min-h-screen bg-[var(--navy-900)] text-white","children":[["$","$L1d",null,{}],["$","script",null,{"id":"blog-post-article-schema","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"How AI Call Handlers Are Changing the Game for UK Trades in 2026\",\"description\":\"AI call handlers transform how UK tradespeople capture leads. From missed calls to £50,000+ recovered revenue. Complete 2026 guide. Plans from £59.\",\"image\":\"https://whoza.ai/og-image.webp\",\"datePublished\":\"2026-05-15\",\"dateModified\":\"2026-05-15\",\"author\":{\"@type\":\"Person\",\"name\":\"Dru McPherson\",\"jobTitle\":\"Founder, whoza.ai\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Whoza.ai\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://whoza.ai/og-image.webp\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://whoza.ai/blog/how-ai-call-handlers-are-changing-the-game-for-uk-trades-2026\"},\"articleSection\":\"AI Voice Agents\",\"wordCount\":1372,\"inLanguage\":\"en-GB\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\"article h1\",\"article h2\",\"article p\"]}}"}}],null,["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1e"}}],["$","$L1f",null,{"items":[{"name":"Home","item":"https://whoza.ai"},{"name":"Blog","item":"https://whoza.ai/blog"},{"name":"How AI Call Handlers Are Changing the Game for UK Trades in 2026","item":"https://whoza.ai/blog/how-ai-call-handlers-are-changing-the-game-for-uk-trades-2026"}]}],"$L20","$L21"]}]
