1e:Tb2d,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much does an AI receptionist cost for a gas engineer?","acceptedAnswer":{"@type":"Answer","text":"whoza.ai's Starter plan costs £59 per month for pay-per-job pricing. That is less than the profit on one average gas engineering job. Most users break even within 48 hours of setup."}},{"@type":"Question","name":"Can AI really understand emergency boiler calls?","acceptedAnswer":{"@type":"Answer","text":"Yes. Katie identifies emergency keywords — no heating, no hot water, gas leak, carbon monoxide alarm — and flags them immediately in the WhatsApp summary. She also asks the right qualifying questions to determine urgency and timeline."}},{"@type":"Question","name":"Do customers know they are talking to AI?","acceptedAnswer":{"@type":"Answer","text":"Most callers cannot tell. Katie uses natural language and a human-like voice. Customers care about getting their problem solved quickly, not about who answers. Several of my customers complimented 'my receptionist' on being helpful."}},{"@type":"Question","name":"What happens to emergency calls with AI answering?","acceptedAnswer":{"@type":"Answer","text":"Emergency calls are answered instantly, qualified, and delivered to your WhatsApp with an urgent flag. Katie asks about the severity and confirms whether it is a safety issue. You see it immediately and can call back within minutes."}},{"@type":"Question","name":"Is a 7-day free trial actually free?","acceptedAnswer":{"@type":"Answer","text":"Yes. No credit card required. No contract. You sign up, connect your number, and test it for a full week. If you do not capture any value, you walk away with zero cost. Most users see their first captured job within 24 hours."}},{"@type":"Question","name":"How quickly can I get set up?","acceptedAnswer":{"@type":"Answer","text":"Under 10 minutes. Connect your existing number via call forwarding, set your greeting and business details, and Katie starts answering immediately. No technical knowledge required. If you can use a smartphone, you can set this up."}},{"@type":"Question","name":"What happens if Katie cannot handle a call?","acceptedAnswer":{"@type":"Answer","text":"Katie captures the core details — name, number, address, and issue — even in difficult cases. If a call is truly complex, she takes a message and flags it for your immediate attention. You never miss the information, even if Katie cannot fully resolve the enquiry."}},{"@type":"Question","name":"Does it work with my existing phone number?","acceptedAnswer":{"@type":"Answer","text":"Yes. whoza.ai uses call forwarding from your existing business number. Your customers dial the same number they always have. Calls forward to Katie only when you do not answer. You keep your established number and reputation."}}]}13:["$","div",null,{"className":"min-h-screen bg-[var(--navy-900)] text-white","children":[["$","$L1d",null,{}],["$","script",null,{"id":"blog-post-article-schema","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"I Worked Out I Was Losing £30,000 a Year to Missed Calls. Then I Tried AI.\",\"description\":\"Gas Safe heating engineer from Walthamstow shares exact maths and 4-week tracked results. How AI call answering recovered £30,000 annual revenue. 2026.\",\"image\":\"https://whoza.ai/og-image.webp\",\"datePublished\":\"2026-06-05\",\"dateModified\":\"2026-06-05\",\"author\":{\"@type\":\"Person\",\"name\":\"Mark Harrison\",\"jobTitle\":\"Gas Safe Heating Engineer, Walthamstow\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Whoza.ai\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://whoza.ai/og-image.webp\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://whoza.ai/blog/i-worked-out-i-was-losing-30000-a-year-to-missed-calls-mark-the-gas-engineer\"},\"articleSection\":\"UGC / Real Stories\",\"wordCount\":2849,\"inLanguage\":\"en-GB\",\"speakable\":{\"@type\":\"SpeakableSpecification\",\"cssSelector\":[\"article h1\",\"article h2\",\"article p\"]}}"}}],null,["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1e"}}],"$L1f","$L20","$L21"]}]
