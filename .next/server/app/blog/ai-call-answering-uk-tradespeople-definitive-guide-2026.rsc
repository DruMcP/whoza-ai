e":"text-white","children":"15+ Trade Verticals"}],["$","p",null,{"className":"text-white/50","children":"Trade-specific AI training, not generic"}]]}]]}],["$","div",null,{"className":"flex items-start gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-check w-5 h-5 text-emerald-400 shrink-0 mt-0.5","children":["$L34","$undefined"]}],"$L35"]}]]}]]}]}]
22:["$","section",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8","children":["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-4","children":"Contents"}],["$","ol",null,{"className":"grid sm:grid-cols-2 gap-3 text-sm text-white/60","children":[["$","li",null,{"children":["$","a",null,{"href":"#what-is","className":"hover:text-emerald-400 transition-colors","children":"1. What Is AI Call Answering?"}]}],["$","li",null,{"children":["$","a",null,{"href":"#problem","className":"hover:text-emerald-400 transition-colors","children":"2. The Problem: Missed Calls Cost Trades Thousands"}]}],["$","li",null,{"children":["$","a",null,{"href":"#how-it-works","className":"hover:text-emerald-400 transition-colors","children":"3. How AI Call Answering Works (Step by Step)"}]}],["$","li",null,{"children":["$","a",null,{"href":"#comparison","className":"hover:text-emerald-400 transition-colors","children":"4. AI vs Human Receptionist vs Voicemail"}]}],["$","li",null,{"children":["$","a",null,{"href":"#trades","className":"hover:text-emerald-400 transition-colors","children":"5. Trade-Specific Benefits"}]}],["$","li",null,{"children":["$","a",null,{"href":"#pricing","className":"hover:text-emerald-400 transition-colors","children":"6. Pricing Guide & Hidden Costs"}]}],["$","li",null,{"children":["$","a",null,{"href":"#roi","className":"hover:text-emerald-400 transition-colors","children":"7. ROI Calculator"}]}],["$","li",null,{"children":["$","a",null,{"href":"#setup","className":"hover:text-emerald-400 transition-colors","children":"8. Setup: Get Started in 30 Minutes"}]}],["$","li",null,{"children":["$","a",null,{"href":"#faq","className":"hover:text-emerald-400 transition-colors","children":"9. Frequently Asked Questions"}]}],["$","li",null,{"children":["$","a",null,{"href":"#cta","className":"hover:text-emerald-400 transition-colors","children":"10. Start Your Free Trial"}]}]]}]]}]}]
23:["$","section",null,{"id":"what-is","className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":[["$","h2",null,{"className":"text-3xl font-bold mb-6 flex items-center gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-headphones w-7 h-7 text-emerald-400","children":[["$","path","1xhozi",{"d":"M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"}],"$undefined"]}],"What Is AI Call Answering?"]}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":"AI call answering is a cloud-based service where an artificial intelligence agent answers phone calls on behalf of your business. Unlike traditional voicemail or call centres, modern AI call handlers use natural language processing (NLP) and large language models to hold genuine conversations with callers. They understand context, ask relevant follow-up questions, and capture structured information about the enquiry."}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":"Here is what happens when a customer calls your business while you are on a job: instead of ringing out, hearing voicemail, and hanging up, they reach a professional AI agent that answers in your business name. The AI confirms your services, asks what the caller needs, captures their name, phone number, address, and job details, and delivers all of this information to your phone within seconds."}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":["The technology has advanced dramatically since early virtual receptionists. Modern AI call answering services like whoza.ai are trained specifically on UK trade terminology. The AI understands \"my combi boiler has no pressure,\" \"I need a consumer unit upgrade,\" \"I've locked myself out,\" and \"my guttering is leaking.\" For plumbing businesses, see our",["$","a",null,{"href":"/for-plumbers","className":"text-emerald-400 hover:underline","children":"AI call answering for plumbers"}]," page. It does not just take a message — it captures the details you actually need to quote and schedule the job."]}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"For UK tradespeople, this means no more missed opportunities, no more playing phone tag with potential customers, and no more discovering three voicemails from yesterday that you never saw. Every call is captured, qualified, and delivered instantly."}]]}]
24:["$","section",null,{"id":"problem","className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":[["$","h2",null,{"className":"text-3xl font-bold mb-6 flex items-center gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chart-column w-7 h-7 text-emerald-400","children":[["$","path","c24i48",{"d":"M3 3v16a2 2 0 0 0 2 2h16"}],["$","path","2bz60n",{"d":"M18 17V9"}],["$","path","1frdt8",{"d":"M13 17V5"}],["$","path","17ska0",{"d":"M8 17v-3"}],"$undefined"]}],"The Problem: Why Missed Calls Destroy Trade Revenue"]}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":["Let us look at the hard numbers. According to the Office for National Statistics (ONS),",["$","strong",null,{"className":"text-white","children":" 62% of calls to small UK businesses go unanswered"}],". For trade businesses, this figure is often higher — plumbers, electricians, and roofers physically cannot answer a phone while crawling under floorboards, on a ladder, or handling live electrics."]}],["$","div",null,{"className":"grid sm:grid-cols-3 gap-4 mb-8","children":[["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-6 text-center","children":[["$","div",null,{"className":"text-4xl font-bold text-red-400 mb-2","children":"62%"}],["$","div",null,{"className":"text-white/60 text-sm","children":"Of calls go unanswered (ONS)"}]]}],["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-6 text-center","children":[["$","div",null,{"className":"text-4xl font-bold text-red-400 mb-2","children":"85%"}],["$","div",null,{"className":"text-white/60 text-sm","children":"Of missed callers never ring back"}]]}],["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl p-6 text-center","children":[["$","div",null,{"className":"text-4xl font-bold text-red-400 mb-2","children":"£25k+"}],["$","div",null,{"className":"text-white/60 text-sm","children":"Annual revenue lost per tradesperson"}]]}]]}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":"The Federation of Small Businesses (FSB) estimates that missed calls cost UK small businesses an average of £1,200 per year. But this average includes businesses with low transaction values. For tradespeople, where a single job can be worth £200–£2,000+, the impact is far greater."}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":["Consider a plumber receiving 10 calls per day. If 6 go unanswered (60%) and each missed call represents a potential job worth £250 with a 50% conversion probability, that is £750 in lost revenue per day. Over 250 working days, that totals ",["$","strong",null,{"className":"text-white","children":"£187,500 in potential annual revenue"}],". Even recovering a small fraction of these calls transforms a tradesperson's bottom line."]}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":"The psychology of missed calls compounds the problem. When a customer with a burst pipe or broken boiler cannot reach you, they experience immediate frustration. They do not wait — they call the next search result. Google research shows that 74% of consumers who search for local services contact multiple businesses. The first to answer often wins the job."}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Traditional solutions fail. Voicemail is where enquiries go to die — 78% of callers hang up without leaving a message. Call forwarding to family members is unreliable and unprofessional. Hiring a human receptionist costs £20,000–£25,000 per year plus National Insurance, pension contributions, and holiday cover. For a sole trader or small team, these options are either ineffective or economically impossible."}]]}]
25:["$","section",null,{"id":"how-it-works","className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12","children":[["$","h2",null,{"className":"text-3xl font-bold mb-6 flex items-center gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-phone w-7 h-7 text-emerald-400","children":[["$","path","foiqr5",{"d":"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"}],"$undefined"]}],"How AI Call Answering Works: The Complete Flow"]}],["$","p",null,{"className":"text-white/70 leading-relaxed mb-6","children":"Understanding the technical flow helps you see why AI call answering is so effective. Here is exactly what happens, step by step, when a customer calls your business."}],["$","div",null,{"className":"space-y-6 mb-8","children":[["$","div",null,{"className":"flex gap-4","children":[["$","div",null,{"className":"w-10 h-10 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center font-bold shrink-0","children":"1"}],["$","div",null,{"children":[["$","h3",null,{"className":"font-semibold text-white mb-1","children":"Call Forwarding Setup"}],["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"You configure your business phone (mobile or landline) to forward unanswered or busy calls to the AI service. This takes 2 minutes on most UK networks. Your customers dial your existing number — they never know calls are being forwarded."}]]}]]}],["$","div",null,{"className":"flex gap-4","children":[["$","div",null,{"className":"w-10 h-10 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center font-bold shrink-0","children":"2"}],["$","div",null,{"children":[["$","h3",null,{"className":"font-semibold text-white mb-1","children":"AI Answers the Call"}],["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"The AI answers within 2–3 rings, introducing itself with your business name. \"Good morning, you're through to Smith Plumbing. I'm your digital assistant. How can I help today?\" The voice is natural and professional — callers often do not realise they are speaking to AI."}]]}]]}],["$","div",null,{"className":"flex gap-4","children":[["$","div",null,{"className":"w-10 h-10 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center font-bold shrink-0","children":"3"}],["$","div",null,{"children":[["$","h3",null,{"className":"font-semibold text-white mb-1","children":"Trade-Specific Qualification"}],["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"The AI asks questions configured for your trade. For plumbing: \"Is this an emergency or routine booking?\" \"What type of property?\" \"What's the issue — leak, boiler, drainage, or something else?\" For electricians: \"Is power completely off or partially affected?\" \"When do you need this done?\" Every answer is captured and structured."}]]}]]}],["$","div",null,{"className":"flex gap-4","children":[["$","div",null,{"className":"w-10 h-10 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center font-bold shrink-0","children":"4"}],["$","div",null,{"children":[["$","h3",null,{"className":"font-semibold text-white mb-1","children":"Contact Details Captured"}],["$","p",null,{"className":"text-white/60 text-sm leading-relaxed","children":"The AI captures the caller's full name, phone number, address, and preferred callback time. It confirms spellings and repeats numbers back to ensure accuracy. No more \"was that a 5 or a 9?\" on garbled voicemails."}]]}]]}],"$L36","$L37"]}],"$L38"]}]
