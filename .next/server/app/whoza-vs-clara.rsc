2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-x w-4 h-4 text-red-400 shrink-0 mt-0.5","children":[["$","path","1bl5f8",{"d":"M18 6 6 18"}],["$","path","d8bk6v",{"d":"m6 6 12 12"}],"$undefined"]}]," Requires opening email app, reading, then action"]}]]}]]}]
