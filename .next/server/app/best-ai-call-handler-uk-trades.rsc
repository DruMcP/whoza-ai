30:["$","section",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16","children":[["$","h2",null,{"className":"text-3xl font-bold text-white mb-8 text-center","children":"Frequently Asked Questions"}],["$","div",null,{"className":"space-y-4","children":[["$","div","0",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"What is an AI call handler?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"An AI call handler is a virtual receptionist powered by artificial intelligence. It answers your business phone 24/7, speaks to callers in a natural voice, captures their details, qualifies the enquiry, and sends you a summary - so you only speak to real jobs."}]]}],["$","div","1",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"How much does an AI call handler cost?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"UK AI call handlers range from £29 to £400 per month. Most trade-specific options fall between £49 and £59 per month. All major providers offer free trials."}]]}],["$","div","2",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"Can an AI call handler book jobs into my calendar?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Yes. Most AI call handlers (including whoza.ai, Clara, and Moneypenny) can integrate with your calendar to book appointments directly. whoza.ai sends booking confirmations via WhatsApp."}]]}],["$","div","3",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"What happens to calls outside business hours?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"AI call handlers work 24/7, including evenings, weekends, and bank holidays. Every call is answered, qualified, and logged - you'll see every enquiry in your WhatsApp or app when you check in the morning."}]]}],["$","div","4",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"Is an AI call handler better than a human receptionist?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"For most UK tradespeople, yes. An AI call handler costs £59/month versus £20,000+/year for a full-time receptionist. It works 24/7, never takes sick leave, and handles unlimited simultaneous calls. The only exception is large firms that need complex customer service - Moneypenny's hybrid model works better there."}]]}],["$","div","5",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"Do I need to change my phone number?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"No. All providers let you keep your existing business number. Calls are forwarded to the AI service, or you can get a new number if you prefer."}]]}],["$","div","6",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold text-white mb-3","children":"Can the AI sound like a real person?"}],["$","p",null,{"className":"text-white/70 leading-relaxed","children":"Yes. Modern AI voices (like those used by whoza.ai and Clara) are indistinguishable from human receptionists. Most callers won't know they're speaking to AI."}]]}],"$L45","$L46","$L47"]}]]}]
