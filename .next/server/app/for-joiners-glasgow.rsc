2a:["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","div",null,{"className":"text-center mb-12","children":[["$","h2",null,{"className":"text-3xl sm:text-4xl font-bold mb-4","children":"Questions Joiners in Glasgow Ask"}],["$","p",null,{"className":"text-white/60","children":"Everything you need to know about AI call answering for joiners in Glasgow."}]]}],["$","div",null,{"className":"space-y-4","children":[["$","div","0",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","itemScope":true,"itemType":"https://schema.org/Question","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","itemProp":"name","children":"How much does AI call answering cost for joiners in Glasgow?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","itemScope":true,"itemType":"https://schema.org/Answer","itemProp":"acceptedAnswer","children":["$","span",null,{"itemProp":"text","children":"whoza.ai starts at £59/month for the Starter plan. That's less than one joiner job in Glasgow. Every plan includes unlimited AI calls, WhatsApp delivery, and a 7-day free trial. Most joiners recover the cost within 48 hours by capturing just one missed job."}]}]]}],["$","div","1",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","itemScope":true,"itemType":"https://schema.org/Question","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","itemProp":"name","children":"Can Katie handle emergency calls for joiners in Glasgow?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","itemScope":true,"itemType":"https://schema.org/Answer","itemProp":"acceptedAnswer","children":["$","span",null,{"itemProp":"text","children":"Absolutely. Katie answers 24/7, including nights, weekends, and bank holidays. She identifies emergency calls and marks them as highest priority in your WhatsApp alert. Whether you're in Glasgow or anywhere in the UK, you'l