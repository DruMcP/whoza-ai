2b:["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","div",null,{"className":"text-center mb-12","children":[["$","h2",null,{"className":"text-3xl sm:text-4xl font-bold mb-4","children":"Questions Electricians in Manchester Ask"}],["$","p",null,{"className":"text-white/60","children":"Everything you need to know about AI call answering for electricians in Manchester."}]]}],["$","div",null,{"className":"space-y-4","children":[["$","div","0",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","itemScope":true,"itemType":"https://schema.org/Question","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","itemProp":"name","children":"How much does AI call answering cost for electricians in Manchester?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","itemScope":true,"itemType":"https://schema.org/Answer","itemProp":"acceptedAnswer","children":["$","span",null,{"itemProp":"text","children":"whoza.ai starts at £59/month for the Starter plan. That's less than one electrician job in Manchester. Every plan includes unlimited AI calls, WhatsApp delivery, and a 7-day free trial. Most electricians recover the cost within 48 hours by capturing just one missed job."}]}]]}],["$","div","1",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","itemScope":true,"itemType":"https://schema.org/Question","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","itemProp":"name","children":"Can Katie handle emergency calls for electricians in Manchester?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","itemScope":true,"itemType":"https://schema.org/Answer","itemProp":"acceptedAnswer","children":["$","span",null,{"itemProp":"text","children":"Absolutely. Katie answers 24/7, including nights, weekends, and bank holidays. She identifies emergency calls and marks them as highest priority in your WhatsApp alert. Whether you're in Manchester or anywhere in the UK, you'll see the emergency tag immediately and can respond within minutes."}]}]]}],["$","div","2",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","itemScope":true,"itemType":"https://schema.org/Question","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","itemProp":"name","children":"What information does Katie collect from electricians customers in Manchester?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","itemScope":true,"itemType":"https://schema.org/Answer","itemProp":"acceptedAnswer","children":["$","span",null,{"itemProp":"text","children":"Katie captures: full name, phone number, Manchester postcode, property type, job description, urgency level, preferred appointment time, and how they found you. For emergencies, she also asks about immediate safety concerns and property damage extent."}]}]]}],["$","div","3",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","itemScope":true,"itemType":"https://schema.org/Question","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","itemProp":"name","children":"Does it work with my existing Manchester business phone number?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","itemScope":true,"itemType":"https://schema.org/Answer","itemProp":"acceptedAnswer","children":["$","span",null,{"itemProp":"text","children":"Yes. You simply set up call forwarding from your existing Manchester business number to your whoza.ai number. Your customers dial the same number they've always used — Katie answers when you can't. Setup takes under 10 minutes and works with both mobile and landline numbers."}]}]]}],["$","div","4",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","itemScope":true,"itemType":"https://schema.org/Question","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","itemProp":"name","children":"How quickly can I get set up as a electrician in Manchester?"}],"$L39"]