l,{"children":"Optifai (2026). 'Lead Response Time Benchmarks: 939 B2B Companies.'"}],["$","li",null,{"children":"Paperclip Research (2025). 'How Many Calls Do UK Businesses Miss?'"}],["$","li",null,{"children":"PATLive (2025). 'Missed Call Statistics and Business Impact.'"}],["$","li",null,{"children":"PwC (2025). 'Future of Customer Experience Report.'"}],["$","li",null,{"children":"SurveyMonkey (2026). 'Customer Service Statistics 2026: Humans vs AI Trends.'"}],["$","li",null,{"children":"Twilio. 'Consumer Handoff Experience Statistics.'"}],["$","li",null,{"children":"Velocify (2012). '1-Minute Response Conversion Research.'"}],["$","li",null,{"children":"Voiso (2026). 'Lead Response Time Metrics.'"}],["$","li",null,{"children":"Zendesk (2026). 'CX Trends Report 2026.' Zendesk Research."}]]}]}]]}]
37:["$","div",null,{"className":"bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-8 mb-10 text-center","children":[["$","p",null,{"className":"text-white/90 leading-relaxed mb-6","children":"Ready to transform your caller experience? Join 1,200+ UK tradespeople who never miss a lead with whoza.ai's AI voice agent, Katie."}],["$","$L20",null,{"href":"/","className":"inline-flex items-center gap-2 px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-xl transition-colors","children":["Start Your Free Trial",["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4 rotate-180","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}]]}]]}]
