40:["$","p",null,{"className":"text-white/80 leading-relaxed mb-4","children":"Despite lower volume, AI search traffic delivers dramatically higher conversion rates:"}]
41:["$","div",null,{"className":"bg-white/5 border border-white/10 rounded-xl overflow-hidden mb-6","children":["$","table",null,{"className":"w-full text-sm","children":[["$","thead",null,{"children":["$","tr",null,{"className":"border-b border-white/10","children":[["$","th",null,{"className":"px-4 py-3 text-left font-semibold text-white/70","children":"Metric"}],["$","th",null,{"className":"px-4 py-3 text-left font-semibold text-white/70","children":"Value"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"className":"border-b border-white/10","children":[["$","td",null,{"className":"px-4 py-3 text-white/80","children":"AI search traffic conversion rate"}],["$","td",null,{"className":"px-4 py-3 font-medium text-emerald-400","children":"14.2%"}]]}],["$","tr",null,{"className":"border-b border-white/10","children":[["$","td",null,{"className":"px-4 py-3 text-white/80","children":"Google organic search conversion rate"}],["$","td",null,{"className":"px-4 py-3 font-medium text-white/80","children":"2.8%"}]]}],["$","tr",null,{"className":"border-b border-white/10","children":[["$","td",null,{"className":"px-4 py-3 text-white/80","children":"AI visitor value multiplier"}],["$","td",null,{"className":"px-4 py-3 font-medium text-emerald-400","children":"5.1x"}]]}],["$","tr",null,{"className":"border-b border-white/10","children":[["$","td",null,{"className":"px-4 py-3 text-white/80","children":"AI search traffic YoY growth"}],["$","td",null,{"className":"px-4 py-3 font-medium text-emerald-400","children":"527%"}]]}],["$","tr",null,{"className":"border-b border-white/10","children":[["$","td",null,{"className":"px-4 py-3 text-white/80","children":"ChatGPT share of all AI referral traffic"}],["$","td",null,{"className":"px-4 py-3 font-medium text-emerald-400","children":"87.4%"}]]}],["$","tr",null,{"children":[["$","td",null,{"className":"px-4 py-3 text-white/80","children":"Brands cited in AI Overviews: click lift"}],["$","td",null,{"className":"px-4 py-3 font-medium text-emerald-400","children":"+35%"}]]}]]}]]}]}]
42:["$","p",null,{"className":"text-white/80 leading-relaxed","children":["AI search traffic increased ",["$","strong",null,{"children":"527% in one year"}]," according to Semrush, growing 165 times faster than organic search traffic. While AI referral traffic currently accounts for only 1.08% of all website traffic, it is growing at approximately 1% month-over-month, and ChatGPT drives 87.4% of all AI referral traffic to websites."]}]
43:["$","p",null,{"className":"text-white/80 leading-relaxed mb-4","children":"Each AI platform favours different source types, requiring platform-specific optimisation strategies:"}]
44:["$","ul",null,{"className":"space-y-2 mb-4","children":[["$","li",null,{"className":"text-white/80","children":[["$","strong",null,{"children":"ChatGPT:"}]," Prefers encyclopaedic, high-authority content. Wikipedia alone captures 7.8% of all browsing-mode citations. Tech publishers, major media outlets, and academic institutions dominate."]}],["$","li",null,{"className":"text-white/80","children":[["$","strong",null,{"children":"Perplexity:"}]," Favours community and user-generated content. Reddit captures 6.6% of citations, significantly higher than on other platforms."]}],["$","li",null,{"className":"text-white/80","children":[["$","strong",null,{"children":"Google AI Overviews:"}]," Distributes citations more evenly across source types, with 76% of cited sources coming from the top 10 organic results — but only 38% of cited pages rank in the top 10, indicating AI Overviews pull from a much wider source pool than organic rankings alone."]}]]}]
45:["$","h3",null,{"className":"text-xl font-semibold text-white mb-3 mt-6","children":"The Freshness Factor"}]
46:["$","p",null,{"className":"text-white/80 leading-relaxed mb-4","children":["Content recency is a critical and often overlooked citation factor. Research found that ",["$","strong",null,{"children":"content updated within 30 days receives 3.2 times more citations"}]," than stale content, and 89.7% of all cited pages had been updated within the current year. Pages not updated quarterly are 3 times more likely to lose AI citations. For small businesses, this means that maintaining current information — service offerings, pricing, business hours, staff details — is not merely good practice but a direct determinant of AI visibility."]}]
47:["$","h3",null,{"className":"text-xl font-semibold text-white mb-3 mt-6","children":"Essential Schema Types for Small Business"}]
48:["$","p",null,{"className":"text-white/80 leading-relaxed mb-4","children":"For small businesses competing in local service markets, four schema types cover approximately 80% of AEO requirements:"}]
49:["$","div",null,{"className":"space-y-3 mb-6","children":[["$","div",null,{"className":"flex items-start gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check-big w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5","children":[["$","path","yps3ct",{"d":"M21.801 10A10 10 0 1 1 17 3.335"}],["$","path","1pflzl",{"d":"m9 11 3 3L22 4"}],"$undefined"]}],["$","div",null,{"children":[["$","h4",null,{"className":"font-semibold text-white mb-1","children":"LocalBusiness Schema"}],["$","p",null,{"className":"text-white/70","children":"Identifies the business as a real entity with physical presence: name, address, phone, service area, hours, reviews, pricing. Foundation for local AI visibility."}]]}]]}],["$","div",null,{"className":"flex items-start gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check-big w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5","children":[["$","path","yps3ct",{"d":"M21.801 10A10 10 0 1 1 17 3.335"}],["$","path","1pflzl",{"d":"m9 11 3 3L22 4"}],"$undefined"]}],["$","div",null,{"children":[["$","h4",null,{"className":"font-semibold text-white mb-1","children":"Service Schema"}],["$","p",null,{"className":"text-white/70","children":"Defines specific services offered, eliminating ambiguity. \"Restoration\" could mean art, water damage, or automotive — Service schema makes the distinction explicit."}]]}]]}],["$","div",null,{"className":"flex items-start gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check-big w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5","children":[["$","path","yps3ct",{"d":"M21.801 10A10 10 0 1 1 17 3.335"}],["$","path","1pflzl",{"d":"m9 11 3 3L22 4"}],"$undefined"]}],["$","div",null,{"children":[["$","h4",null,{"className":"font-semibold text-white mb-1","children":"FAQPage Schema"}],["$","p",null,{"className":"text-white/70","children":"Wraps FAQ content in structures AI can extract as pre-packaged Q&A pairs. Highest-value schema for citations. FAQ content with proper FAQPage schema produced 350% more AI citations."}]]}]]}],["$","div",null,{"className":"flex items-start gap-3","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check-big w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5","children":[["$","path","yps3ct",{"d":"M21.801 10A10 10 0 1 1 17 3.335"}],["$","path","1pflzl",{"d":"m9 11 3 3L22 4"}],"$undefined"]}],["$","div",null,{"children":[["$","h4",null,{"className":"font-semibold text-white mb-1","children":"Review / AggregateRating Schema"}],["$","p",null,{"className":"text-white/70","children":"Communicates customer satisfaction in machine-readable format. Brands with review platform profiles have 3x higher citation chances."}]]}]]}]]}]
4a:["$","h3",null,{"className":"text-xl font-semibold text-white mb-3 mt-6","children":"The Completeness Imperative"}]
4b:["$","p",null,{"className":"text-white/80 leading-relaxed mb-4","children":["AccuraCast's analysis of over 2,000 prompts across ChatGPT, Google AI Overviews, and Perplexity — reviewing 9,000 cited sources — found that ",["$","strong",null,{"children":"81% of cited pages have schema"}],". However, the critical insight is that schema type alone does not determine citation. Authority and content quality do. Schema is what makes that authority machine-readable."]}]
4c:["$","p",null,{"className":"text-white/80 leading-relaxed","children":"Research consistently shows that thin schema — a type declared but properties mostly empty — performs worse than no schema at all. A page that claims to be an Article but provides no author, no date, and no description creates noise without context. Complete schema, with every relevant property populated, is what moves the needle."}]
