-4 sm:px-6 py-12 sm:py-16","children":[["$","div",null,{"className":"article-abstract bg-[#1A2332] border border-white/[0.06] rounded-xl p-6 sm:p-8 mb-12","children":[["$","h2",null,{"className":"text-xl font-semibold text-white mb-4","children":"Executive Summary"}],["$","div",null,{"className":"text-white/70 leading-relaxed space-y-4","children":[["$","p",null,{"children":"The field of AI voice agents has undergone a paradigm shift between 2024 and 2026, driven by the transition from stitched, component-based speech pipelines to end-to-end neural speech models capable of native audio processing. This report provides a comprehensive technical and market analysis of voice agent technology at its current state of the art."}],"$L20"]}]]}],"$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c"]}]]}]
