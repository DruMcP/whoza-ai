00","children":"None"}]]}],["$","tr",null,{"className":"border-b border-white/5 bg-white/5","children":[["$","td",null,{"className":"p-3","children":"Office space/equipment"}],["$","td",null,{"className":"p-3","children":"£500-£1,500"}],["$","td",null,{"className":"p-3 text-emerald-400","children":"None"}]]}],["$","tr",null,{"className":"border-b-2 border-emerald-500/30 font-semibold text-white","children":[["$","td",null,{"className":"p-3","children":"Total annual cost"}],["$","td",null,{"className":"p-3","children":"£27,800-£38,700"}],["$","td",null,{"className":"p-3","children":"£708-£1,500"}]]}],["$","tr",null,{"className":"font-semibold text-white","children":[["$","td",null,{"className":"p-3","children":"Cost per answered call"}],["$","td",null,{"className":"p-3","children":"£2.40-£3.30"}],["$","td",null,{"className":"p-3","children":"£0.08-£0.15"}]]}]]}]]}],["$","p",null,{"className":"text-sm text-white/50 text-center mt-2","children":"Table 2: Annual Cost Comparison — Human Receptionist vs AI Receptionist"}]]}]
35:["$","p",null,{"children":["The headline figure is stark: an AI receptionist costs 94-98% less than a human receptionist while providing capabilities no human can match. AI agents answer unlimited simultaneous calls — a human can handle only one at a time. AI agents work 24/7, 365 days a year. See our ",["$","$L2e",null,{"href":"/blog/ai-receptionist-vs-human-cost-guide-2026","className":"text-emerald-400 hover:underline","children":"detailed cost comparison blog post"}]," for the full breakdown."]}]
