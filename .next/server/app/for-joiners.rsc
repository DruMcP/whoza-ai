me":"text-lg font-semibold mb-3","children":"Can Katie handle bespoke furniture enquiries?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Absolutely. Katie is trained to handle detailed joinery enquiries including bespoke kitchens, fitted wardrobes, staircases, doors, and cabinets. She captures project type, materials preference, budget range, timeline, and dimensions — giving you a full brief before you even call back. Customers describing complex projects are guided through the key details Katie needs to collect."}}]]}],["$","div","3",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"What information does Katie collect from joinery customers?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie captures: full name, phone number, postcode, project type (kitchen, wardrobe, staircase, door, window, etc.), materials preference (hardwood, oak, walnut, pine, MDF), budget range, timeline, property type (house/flat/commercial), and whether it's a commercial or residential client. For bespoke projects, she also asks about style preferences and whether plans or drawings are available."}}]]}],["$","div","4",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"Will customers know they're talking to AI?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie introduces herself as your digital assistant with a natural, professional voice. Most callers appreciate the instant response over voicemail or a ringing phone. In user surveys, 89% of callers are satisfied with the AI experience — they just want their joinery project discussed promptly and professionally."}}]]}],"$L4e","$L4f","$L50","$L51"]}],"$L52"]}]}]
