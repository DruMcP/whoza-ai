4e:["$","div","5",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"Does it work with my existing business phone number?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. You simply set up call forwarding from your existing joinery business number to your whoza.ai number. Your customers dial the same number they've always used — Katie just answers when you can't. Setup takes under 10 minutes."}}]]}]
4f:["$","div","6",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"How quickly can I get set up?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Most joiners are live and capturing calls within 30 minutes. Sign up, connect your number via call forwarding, set your greeting and business details, and Katie starts answering immediately. No hardware, no IT team, no technical knowledge required."}}]]}]
50:["$","div","7",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"Can Katie handle commercial joinery contracts?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie identifies commercial enquiries from builders, developers, architects, and interior designers. She captures project scale, contract value, timeline, and decision-maker details. Commercial enquiries are tagged as priority in your WhatsApp alert so you can follow up fast — these are often your highest-value jobs."}}]]}]
