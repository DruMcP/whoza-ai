4c:["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Most landscapers are live and capturing calls within 30 minutes. Sign up, connect your number via call forwarding, set your greeting and business details, and Katie starts answering immediately. No hardware, no IT team, no technical knowledge required."}}]
4d:["$","div","6",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"Can Katie handle emergency storm damage calls?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie answers 24/7 including nights, weekends, and bank holidays. She identifies emergency keywords like 'storm damage', 'fallen tree', 'flooding', and 'dangerous branches' — then marks the enquiry as emergency priority in your WhatsApp alert. You see it immediately and can respond within minutes."}}]]}]
4e:["$","div","7",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"What happens if Katie can't handle a complex enquiry?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie is trained to recognise when a call needs human attention. For complex garden design consultations or unusual projects, she takes a detailed message and flags it for your immediate callback. You receive the full context in WhatsApp so you can call back prepared with all the details."}}]]}]
