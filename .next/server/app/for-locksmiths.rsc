48:["$","section",null,{"id":"faq","className":"section-padding-lg bg-white relative","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","div",null,{"className":"text-center mb-12","children":[["$","span",null,{"className":"inline-block px-4 py-1.5 rounded-full bg-[var(--katie-blue)]/10 text-[var(--katie-blue)] text-sm font-medium mb-4","children":"Got Questions?"}],["$","h2",null,{"className":"text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--navy-900)] tracking-tight text-balance","children":"Locksmith FAQ"}],["$","p",null,{"className":"mt-6 text-lg text-[var(--slate-500)]","children":"Everything you need to know about AI call handling for locksmith businesses"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","div","0",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"How much does AI call handling cost for locksmiths?"}],["$","div",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Whoza.ai starts at £59/month for the Starter plan. One captured emergency lockout averages £80-£150 callout fee. A full security upgrade can be £500-£2,000. At £59/month, one emergency lockout callout pays for the entire year. Overage minutes are billed at £0.26/minute. No hidden fees or contracts."}}],["$","p",null,{"className":"mt-2 text-sm","children":[["$","$L22",null,{"href":"/pricing","className":"text-[var(--katie-blue)] hover:underline","children":"Plans start at £59/month"}],". See full pricing and plan details."]}]]}],["$","div","1",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Can Katie handle emergency lockout calls at 3am?"}],["$","div",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie answers 24/7, 365 days a year. She identifies lockout emergencies by keywords like 'locked out', 'lost keys', 'broken key', 'snapped key', 'can't get in', 'urgent', and 'emergency' — and marks the enquiry as emergency priority. You get an immediate WhatsApp with 'LOCKOUT EMERGENCY — URGENT' in the header, even at 3am on Christmas Day."}}],false]}],["$","div","2",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"What information does Katie collect from lockout customers?"}],["$","div",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie collects: full name, phone number, postcode, property type (house/flat/commercial), lock type (if known — Yale, Chubb, euro cylinder, mortice, digital), how they got locked out (lost keys, broken key, snapped in lock, locked inside, lock failure), whether it's a tenant or landlord situation, number of locks affected, and how they found you."}}],false]}],["$","div","3",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Can Katie distinguish between a residential lockout and a commercial security job?"}],["$","div",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie is trained to identify the type of locksmith job from the customer's description. 'Locked out of my house' gets residential lockout priority. 'Need to change all locks on my rental property' gets landlord/multi-property tagging. 'Security survey for my shop' gets commercial security priority. Each type gets different follow-up handling in your dashboard."}}],false]}],"$L6f","$L70","$L71","$L72"]}]]}]}]
