6f:["$","div","4",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Does Katie handle UPVC door lock and window lock enquiries?"}],["$","div",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie recognises UPVC-specific terminology like 'euro cylinder', 'multipoint lock', 'mechanism failure', 'window lock', 'patio door', and 'French door'. She captures the specific issue and marks it as 'UPVC specialist' in your dashboard so you know to bring the right replacement parts."}}],false]}]
70:["$","div","5",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"How does whoza.ai help with key cutting and key replacement enquiries?"}],["$","div",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie captures key replacement enquiries with: type of key (house key, car key, safe key, padlock key), whether it's a standard key or high-security key, number of copies needed, and whether the customer can bring the lock or key to you. She can also ask if they need the lock rekeyed or just a key cut."}}],false]}]
71:["$","div","6",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Can Katie handle calls about security upgrades and CCTV?"}],["$","div",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie identifies security upgrade calls by keywords like 'security survey', 'CCTV', 'alarm', 'smart lock', 'digital lock', 'keyless entry', and 'high security'. She captures: property type, number of entry points, current security level, budget range, and preferred survey date. These high-value enquiries (£500-£3,000+) get flagged as 'security upgrade' for priority follow-up."}}],false]}]
72:["$","div","7",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Will customers trust an AI with their lockout emergency?"}],["$","div",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie introduces herself as your AI assistant and explains that she's capturing details so you can respond immediately. Most lockout customers are relieved to speak to someone right away rather than leaving a voicemail. Katie reassures them that their locksmith has been notified and will call back within minutes. In our surveys, 89% of callers are satisfied with the AI experience."}}],false]}]
