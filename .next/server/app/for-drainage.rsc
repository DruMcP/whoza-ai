51:["$","div","5",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"Does it work with my existing business phone number?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. You simply set up call forwarding from your existing drainage business number to your whoza.ai number. Your customers dial the same number they've always used — Katie just answers when you can't. Setup takes under 10 minutes."}}]]}]
52:["$","div","6",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"How quickly can I get set up?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Most drainage companies are live and capturing calls within 30 minutes. Sign up, connect your number via call forwarding, set your greeting and business details, and Katie starts answering immediately. No hardware, no IT team, no technical knowledge required."}}]]}]
53:["$","div","7",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"Can Katie handle insurance claim drainage calls?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie is trained to recognise insurance-related enquiries. She captures policy details, loss adjuster information, claim reference numbers, and the nature of the drainage damage. She tags these as 'Insurance Claim' in your WhatsApp alert so you can prioritise them. Insurance drainage jobs typically pay £800+ per job."}}]]}]
