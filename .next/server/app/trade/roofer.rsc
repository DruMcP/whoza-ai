27:T475,{"@context":"https://schema.org","@type":"VideoObject","name":"Whoza.ai Demo — AI Call Handling for Roofers","description":"Watch how Whoza.ai's Katie captures a missed enquiry in under 60 seconds for Roofers. The call is answered instantly, the enquiry lands in WhatsApp, and you accept or decline in two taps.","thumbnailUrl":["https://whoza.ai/og-image.png","https://whoza.ai/og-image-1200x630.png"],"uploadDate":"2026-05-06T00:00:00+00:00","duration":"PT60S","contentUrl":"https://whoza.ai/whoza-explainer.mp4","embedUrl":"https://whoza.ai/trade/roofer","author":{"@type":"Organization","name":"Whoza.ai","url":"https://whoza.ai","logo":{"@type":"ImageObject","url":"https://whoza.ai/logo.png","width":512,"height":512}},"publisher":{"@type":"Organization","name":"Whoza.ai","url":"https://whoza.ai"},"potentialAction":{"@type":"WatchAction","target":{"@type":"EntryPoint","urlTemplate":"https://whoza.ai/trade/roofer","actionPlatform":["http://schema.org/DesktopWebPlatform","http://schema.org/MobileWebPlatform"]},"expectsAcceptanceOf":{"@type":"Offer","price":"0","priceCurrency":"GBP","availability":"https://schema.org/InStock"}}}22:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$27"}}]
