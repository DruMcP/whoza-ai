12:T479,{"@context":"https://schema.org","@type":"VideoObject","name":"Whoza.ai for Tilers — AI Call Answering Demo","description":"Watch Katie capture a missed tiling enquiry in under 60 seconds. Bathroom renovation call answered instantly, project details sent to WhatsApp, quote prepared while the tiler is still on the job.","thumbnailUrl":["https://whoza.ai/og-image.png","https://whoza.ai/og-image-1200x630.png"],"uploadDate":"2026-05-06T00:00:00+00:00","duration":"PT60S","contentUrl":"https://whoza.ai/whoza-explainer.mp4","embedUrl":"https://whoza.ai/for-tilers","author":{"@type":"Organization","name":"Whoza.ai","url":"https://whoza.ai","logo":{"@type":"ImageObject","url":"https://whoza.ai/logo.png","width":512,"height":512}},"publisher":{"@type":"Organization","name":"Whoza.ai","url":"https://whoza.ai"},"potentialAction":{"@type":"WatchAction","target":{"@type":"EntryPoint","urlTemplate":"https://whoza.ai/for-tilers","actionPlatform":["http://schema.org/DesktopWebPlatform","http://schema.org/MobileWebPlatform"]},"expectsAcceptanceOf":{"@type":"Offer","price":"0","priceCurrency":"GBP","availability":"https://schema.org/InStock"}}}15:Tef9,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much does AI call answering cost for tilers?","acceptedAnswer":{"@type":"Answer","text":"whoza.ai starts at <a href=\"/pricing\" className=\"text-amber-400 hover:text-amber-300 underline\">plans start at £59/month</a> for the Starter plan. That's less than one small bathroom tiling job. You get unlimited AI call answering, WhatsApp delivery, and a 7-day free trial with no credit card required. Most tilers recover the cost within a week by capturing just one missed enquiry."}},{"@type":"Question","name":"How does AI call answering work?","acceptedAnswer":{"@type":"Answer","text":"Katie uses advanced AI to answer your business calls 24/7, capture customer details, and send structured alerts to your WhatsApp. Read our <a href=\"/blog/ai-call-answering-uk-tradespeople-definitive-guide-2026\" className=\"text-amber-400 hover:text-amber-300 underline\">complete guide to AI call answering</a> for UK trades to learn more."}},{"@type":"Question","name":"Can Katie handle builder and developer enquiries?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. Builder and developer enquiries are automatically tagged as priority in your WhatsApp alert. Katie captures project scope, timeline, site address, and contact details — everything you need to quote fast. These are your biggest repeat customer base, so they get VIP treatment."}},{"@type":"Question","name":"What information does Katie collect from tiling customers?","acceptedAnswer":{"@type":"Answer","text":"Katie captures: full name, phone number, postcode, project type (bathroom, kitchen, floor, wall, commercial), room size, tile type preference, budget range, timeline, commercial or residential, builder or direct customer, and how they found you. She also asks about underfloor heating, mosaic work, and repair vs full installation."}},{"@type":"Question","name":"Will customers know they're talking to AI?","acceptedAnswer":{"@type":"Answer","text":"Katie introduces herself as your digital assistant with a natural, professional voice. Most callers appreciate the instant response over voicemail or a ringing phone. In user surveys, 89% of callers are satisfied with the AI experience — they just want their tiling project booked fast."}},{"@type":"Question","name":"Does it work with my existing business phone number?","acceptedAnswer":{"@type":"Answer","text":"Yes. You simply set up call forwarding from your existing tiling business number to your whoza.ai number. Your customers dial the same number they've always used — Katie just answers when you can't. Setup takes under 10 minutes."}},{"@type":"Question","name":"How quickly can I get set up?","acceptedAnswer":{"@type":"Answer","text":"Most tilers are live and capturing calls within 30 minutes. Sign up, connect your number via call forwarding, set your greeting and business details, and Katie starts answering immediately. No hardware, no IT team, no technical knowledge required."}},{"@type":"Question","name":"Can Katie handle commercial tiling projects?","acceptedAnswer":{"@type":"Answer","text":"Yes. Commercial enquiries (offices, retail, hotels) are automatically marked as urgent. Katie captures project size, deadline, site contact, and whether it's a new build or renovation. She flags tight-deadline projects so you can respond immediately and secure the contract."}},{"@type":"Question","name":"What happens if Katie can't handle a complex enquiry?","acceptedAnswer":{"@type":"Answer","text":"Katie is trained to recognise when a call needs human attention. For complex custom projects or unusual materials, she takes a detailed message and flags it for your immediate callback. You receive the full context in WhatsApp so you can call back prepared with all the details."}}]}7:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$12"}}],["$","$L13",null,{}],["$","$L14",null,{"items":[{"name":"Home","item":"https://whoza.ai"},{"name":"For Tilers","item":"https://whoza.ai/for-tilers"}]}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$15"}}],"$L16","$L17","$L18","$L19","$L1a","$L1b"],null,"$L1c"]}]
