5f:["$","div","3",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] p-8","children":[["$","div",null,{"className":"w-12 h-12 rounded-xl bg-[var(--katie-blue)]/10 flex items-center justify-center mb-4","children":["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-palette w-6 h-6 text-[var(--katie-blue)]","children":[["$","circle","1okk4w",{"cx":"13.5","cy":"6.5","r":".5","fill":"currentColor"}],["$","circle","f64h9f",{"cx":"17.5","cy":"10.5","r":".5","fill":"currentColor"}],["$","circle","fotxhn",{"cx":"8.5","cy":"7.5","r":".5","fill":"currentColor"}],["$","circle","qy21gx",{"cx":"6.5","cy":"12.5","r":".5","fill":"currentColor"}],["$","path","12rzf8",{"d":"M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"}],"$undefined"]}]}],["$","h3",null,{"className":"text-xl font-bold text-[var(--navy-900)] mb-3","children":"Colour-matching emergency calls need context voicemail can't capture"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","children":"A customer calls — 'I need the lounge ceiling repainted after a leak, and it needs to match the walls exactly'. A voicemail says nothing about the existing colour, finish type, or urgency. Katie captures: room size, existing paint brand/colour (if known), surface damage extent, and whether it's insurance work — so you arrive with colour cards and samples."}]]}]
6e:["$","div","4",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Does Katie handle commercial painting and decorating enquiries?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie identifies commercial calls by keywords like 'office', 'shop', 'restaurant', 'hotel', 'landlord', 'letting agent', 'property management', and 'multiple properties'. She captures: business name, property type, number of rooms/units, whether it's a one-off or ongoing contract, insurance requirements, and preferred survey date. Commercial enquiries get flagged as 'commercial' for priority handling."}}]]}]
6f:["$","div","5",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"How does whoza.ai help with landlord and letting agent enquiries?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie recognises landlord-specific terminology like 'between tenancies', 'check-out', 'end of tenancy', 'rental property', and 'letting agent'. She captures: number of properties, property type, room count, whether it's a refresh or full repaint, preferred dates between tenancies, and agent contact details. These recurring maintenance jobs build predictable, repeat revenue."}}]]}]
70:["$","div","6",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Can Katie handle wallpapering and specialist finish enquiries?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie captures wallpapering, coving, cornicing, feature walls, lime washing, Venetian plaster, and other specialist finish enquiries. She asks about: type of finish, room dimensions, whether wallpaper is supplied, pattern matching requirements, and whether old wallpaper needs stripping. Specialist jobs get flagged so you know to bring the right tools and skills."}}]]}]
71:["$","div","7",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Will customers trust an AI with their home painting project?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie introduces herself as your AI assistant and explains that she's capturing details so you can provide an accurate quote. Most customers appreciate the immediate response and detailed information gathering. In our surveys, 89% of callers are satisfied with the AI experience, and painting customers particularly like that Katie captures room sizes, surface conditions, and colour preferences — saving time on the initial quote call."}}]]}]
