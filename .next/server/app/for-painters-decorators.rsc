4b:["$","section",null,{"id":"faq","className":"section-padding-lg bg-white relative","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","div",null,{"className":"text-center mb-12","children":[["$","span",null,{"className":"inline-block px-4 py-1.5 rounded-full bg-[var(--katie-blue)]/10 text-[var(--katie-blue)] text-sm font-medium mb-4","children":"Got Questions?"}],["$","h2",null,{"className":"text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--navy-900)] tracking-tight text-balance","children":"Painter & Decorator FAQ"}],["$","p",null,{"className":"mt-6 text-lg text-[var(--slate-500)]","children":"Everything you need to know about AI call handling for painting and decorating businesses"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","div","0",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"How much does AI call handling cost for painters and decorators?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Whoza.ai starts at £59/month for the Starter plan. One captured interior painting job for a 3-bedroom house averages £1,200-£2,500. A full exterior repaint can be £3,000-£8,000. At £59/month, one missed room repaint pays for the entire year. Overage minutes are billed at £0.26/minute. No hidden fees or contracts."}}]]}],["$","div","1",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Can Katie handle emergency painting and touch-up calls?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie identifies urgent painting enquiries like 'water stain on ceiling', 'peeling paint after leak', 'mould on walls', 'scuff marks before house sale', and 'tenant check-out painting'. She marks these as priority and captures the full context — room size, surface type, colour match requirements, and timeline — so you arrive prepared with the right paint and tools."}}]]}],["$","div","2",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"What information does Katie collect from painting customers?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie collects: full name, phone number, postcode, property type (house/flat/commercial), job type (interior/exterior/both), room count and sizes (if known), surface type (plaster/wood/UPVC/metal), current condition (fresh paint/overpaint/damage repair), colour preferences, timeline, whether materials are included in quote, and how they found you."}}]]}],["$","div","3",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Can Katie distinguish between a quick touch-up and a full house repaint?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie is trained to qualify painting jobs by scope. 'One wall in the lounge' gets small-job tagging. 'Full exterior including soffits and fascias' gets large-project tagging with budget qualification. 'Commercial office repaint' gets commercial tagging. Each type gets appropriate follow-up handling in your dashboard, so you prioritise high-value jobs."}}]]}],"$L6e","$L6f","$L70","$L71"]}]]}]}]
