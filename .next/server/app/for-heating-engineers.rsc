49:["$","section",null,{"id":"faq","className":"section-padding-lg bg-white relative","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","div",null,{"className":"text-center mb-12","children":[["$","span",null,{"className":"inline-block px-4 py-1.5 rounded-full bg-[var(--katie-blue)]/10 text-[var(--katie-blue)] text-sm font-medium mb-4","children":"Got Questions?"}],["$","h2",null,{"className":"text-3xl sm:text-4xl lg:text-5xl font-bold text-[var(--navy-900)] tracking-tight text-balance","children":"Heating Engineer FAQ"}],["$","p",null,{"className":"mt-6 text-lg text-[var(--slate-500)]","children":"Everything you need to know about AI call handling for heating engineering businesses"}]]}],["$","div",null,{"className":"space-y-4","children":[["$","div","0",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"How much does AI call handling cost for heating engineers?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Whoza.ai starts at £59/month for the Starter plan. One captured boiler breakdown averages £120-£200 callout. A full boiler replacement can be £2,500-£4,500. At £59/month, one emergency callout pays for the whole year. Overage minutes are billed at £0.26/minute."}}],["$","p",null,{"className":"mt-2 text-sm","children":[["$","a",null,{"href":"/pricing","className":"text-[var(--katie-blue)] hover:underline","children":"Plans start at £59/month"}],". See full pricing and plan details."]}],false]}],["$","div","1",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Can Katie handle emergency boiler breakdown calls at 6am on a Sunday?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie answers 24/7, including weekends, bank holidays, and early mornings. She identifies emergency heating keywords like 'no heating', 'no hot water', 'boiler not working', 'leaking boiler', 'pilot light out', 'pressure dropped' — and marks the enquiry as emergency priority. You get an immediate WhatsApp with 'BOILER EMERGENCY — URGENT' in the header, even at 2am on Christmas morning."}}],false,false]}],["$","div","2",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"What information does Katie collect from heating customers?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie collects: full name, phone number, postcode, property type (house/flat/commercial), boiler make and model (if known), fault description (no heating/no hot water/leaking/strange noise/pressure issue/pilot light), property age, whether it's a rented property, landlord details if applicable, and how they found you."}}],false,false]}],["$","div","3",{"className":"bg-[var(--off-white)] rounded-xl border border-[var(--border)] px-6 py-5","children":[["$","h3",null,{"className":"text-[var(--navy-900)] font-semibold mb-2","children":"Can Katie distinguish between a service call and an emergency breakdown?"}],["$","p",null,{"className":"text-[var(--slate-500)] leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie is trained to identify urgency from the customer's language. 'Annual service' or 'gas safety certificate' goes to routine scheduling. 'No heating', 'leaking boiler', 'strange smell', or 'pilot light keeps going out' gets emergency priority. She also asks specific diagnostic questions to help you assess urgency before you even call back."}}],false,false]}],"$L78","$L79","$L7a","$L7b"]}]]}]}]
