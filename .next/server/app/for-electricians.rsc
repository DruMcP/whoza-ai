4a:["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Most electricians are live and capturing calls within 30 minutes. Sign up, connect your number via call forwarding, set your greeting and business details, and Katie starts answering immediately. No hardware, no IT team, no technical knowledge required. You can test it with a call from your own phone within minutes."}}]
4b:["$","div","6",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"Can Katie book electrical appointments directly into my calendar?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Yes. Katie checks your connected calendar availability and offers specific time slots to customers. When they confirm, the appointment is saved to your calendar and both parties receive confirmation. For EICRs and routine work, she can offer morning or afternoon slots. For emergencies, she flags them for immediate callback."}}]]}]
4c:["$","div","7",{"className":"bg-white/5 border border-white/10 rounded-xl p-6","children":[["$","h3",null,{"className":"text-lg font-semibold mb-3","children":"What happens if Katie can't handle a complex electrical enquiry?"}],["$","p",null,{"className":"text-white/60 leading-relaxed","dangerouslySetInnerHTML":{"__html":"Katie recognises when a call needs human attention — for complex rewiring quotes, three-phase commercial work, or unusual situations. She takes a detailed message, captures all available context, and flags it for your immediate callback. You receive the full details in WhatsApp so you can call back fully prepared."}}]]}]
