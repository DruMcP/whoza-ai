VITE_SUPABASE_URL=https://ryeqbewlmaqewsuvuhlm.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ5ZXFiZXdsbWFxZXdzdXZ1aGxtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDAwNjYyNzQsImV4cCI6MjA1NTY0MjI3NH0.2z3ii0wYdSVEQqVaD60m9ND_vVM9I2guoIoYBKbG0yw
# Access token for CLI operations and deployments
# Get from https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# Cloudflare Turnstile Configuration
# Get site key and secret key from https://dash.cloudflare.com/
# Used for: Bot protection on Free Score form
# Cost: Free tier available
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# Note: Site key is configured in FreeScore.jsx

# Resend Email API Configuration
# Get your API key from https://resend.com/api-keys
# Used for: Free VCS email delivery, notification system
# Cost: Free tier available (100 emails/day)
VITE_RESEND_API_KEY=your-resend-api-key

# Google Places API Configuration (RECOMMENDED FOR PRODUCTION)
# Get your API key from https://console.cloud.google.com/apis/credentials
# Required APIs: Places API, Maps JavaScript API
# Used for: Business verification, accurate visibility scoring
# Cost: ~$1-3/month for typical usage (with caching)
# See GOOGLE_PLACES_SETUP.md for detailed setup instructions
VITE_GOOGLE_PLACES_API_KEY=your-google-places-api-key

# OpenAI API Configuration (OPTIONAL - AI-Enhanced Features)
# Get your API key from https://platform.openai.com/api-keys
# Used for: Rex AI decision engine, intelligent task generation
# Cost: Pay-as-you-go (~$5-20/month depending on usage)
# Note: Falls back to template-based system if not configured
VITE_OPENAI_API_KEY=your-openai-api-key

# Perplexity API Configuration (OPTIONAL - Advanced Visibility Checks)
# Get your API key from https://www.perplexity.ai/settings/api
# Used for: Advanced AI search visibility analysis
# Cost: Pay-as-you-go
# Note: Feature disabled if not configured
VITE_PERPLEXITY_API_KEY=your-perplexity-api-key

# Custom Domain Configuration (Update after deployment)
# VITE_APP_URL=https://yourdomain.com

# Stripe Configuration (REQUIRED FOR PAYMENTS)
# Add these to Supabase Edge Function Secrets (NOT .env file)
# Get from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_... or sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Environment Mode
# NODE_ENV=production
