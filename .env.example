# whoza.ai Environment Variables Template
# Copy to .env.local (dev) or .env.staging (staging)

# ═══════════════════════════════════════════════════
# SUPABASE (Staging Database)
# ═══════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ═══════════════════════════════════════════════════
# TRILLET.AI (Voice Agent Platform)
# ═══════════════════════════════════════════════════
# ⚠️ LEAVE EMPTY FOR MOCK MODE (safe for dev, no calls placed)
# Fill in when trial starts (May 23–29)
TRILLET_API_KEY=
TRILLET_BASE_URL=https://api.trillet.ai/v1
TRILLET_WORKSPACE_ID=whoza-workspace
TRILLET_AGENT_ID=katie-agent
# Set after trial starts for webhook signature verification
TRILLET_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════
# SITE CONFIG
# ═══════════════════════════════════════════════════
NEXT_PUBLIC_SITE_URL=https://whoza-ai-staging-349.netlify.app
ENVIRONMENT=staging

# ═══════════════════════════════════════════════════
# EMAIL (Resend)
# ═══════════════════════════════════════════════════
RESEND_API_KEY=re_xxxxxxxx

# ═══════════════════════════════════════════════════
# REX (AI Visibility Engine)
# ═══════════════════════════════════════════════════
GOOGLE_PLACES_API_KEY=AIzaSyxxxx
PERPLEXITY_API_KEY=pplx-xxxx

# ═══════════════════════════════════════════════════
# WHATSAPP DELIVERY (Choose one)
# ═══════════════════════════════════════════════════
# Option A: Twilio (fastest setup)
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_WHATSAPP_FROM=+1415xxxx
# Option B: Meta Business API (cheapest long-term)
# META_WHATSAPP_ACCESS_TOKEN=EAxxxx
# META_WHATSAPP_PHONE_NUMBER_ID=1xxxx
# Option C: Trillet native (check if included)
# (No extra vars needed — handled by Trillet)

# ═══════════════════════════════════════════════════
# OPTIONAL: Monitoring / Analytics
# ═══════════════════════════════════════════════════
# NEXT_PUBLIC_GA_ID=G-XXXX
# SENTRY_DSN=https://xxxx.ingest.sentry.io/xxxx
